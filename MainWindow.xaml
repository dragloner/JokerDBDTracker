<Window x:Class="JokerDBDTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="JokerDBD Tracker"
        Width="1500"
        Height="920"
        MinWidth="1060"
        MinHeight="640"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="CanResize"
        Icon="Assets/app.ico"
        Background="#131B22"
        FontFamily="Bahnschrift SemiCondensed"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/MainWindow.Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="MainRootBorder"
            Margin="14"
            Padding="14"
            Background="{StaticResource AppBackground}"
            CornerRadius="26"
            MouseLeftButtonDown="MainRootBorder_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="0"/>
                <RowDefinition Height="0"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="18"
                    CornerRadius="18"
                    Background="#D2162330"
                    BorderBrush="#4D728C"
                    BorderThickness="1"
                    MouseLeftButtonDown="TopHeaderBorder_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="JokerDBD Tracker"
                                   Foreground="#EDF7FF"
                                   FontSize="44"
                                   FontWeight="ExtraBold"/>
                        <StackPanel Margin="3,-2,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="AppVersionText"
                                       Text="v1.4.0"
                                       Foreground="#B9CFDF"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="UpdateStatusText"
                                       Margin="12,0,0,0"
                                       Text="● Проверка обновлений..."
                                       Foreground="#E2C17A"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="UpdateProgramButton"
                                    Margin="12,0,0,0"
                                    Padding="10,4"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Content="Обновить программу"
                                    Visibility="Collapsed"
                                    Click="UpdateProgramButton_Click"/>
                            <Button x:Name="RestartProgramButton"
                                    Margin="8,0,0,0"
                                    Padding="10,4"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Content="Перезапустить программу"
                                    Visibility="Collapsed"
                                    Click="RestartProgramButton_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Margin="8,0,0,0"
                            CornerRadius="22"
                            BorderBrush="#547B97"
                            BorderThickness="1"
                            Background="#D5172431"
                            Height="50"
                            VerticalAlignment="Center">
                        <Grid>
                            <TextBox x:Name="SearchBox"
                                     VerticalAlignment="Center"
                                     FontSize="20"
                                     FontWeight="SemiBold"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     TextChanged="SearchBox_TextChanged"/>
                        <TextBlock x:Name="SearchPlaceholderText" Text="Поиск стримов..."
                                    Foreground="#8FB4CC"
                                    FontWeight="Bold"
                                   FontSize="18"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Text, ElementName=SearchBox}" Value=""/>
                                                <Condition Binding="{Binding IsKeyboardFocused, ElementName=SearchBox}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        </Grid>
                    </Border>

                    <ComboBox x:Name="SortModeBox"
                              Grid.Column="2"
                              Margin="8,0,0,0"
                              VerticalAlignment="Center"
                              SelectionChanged="SortModeBox_SelectionChanged"
                              SelectedIndex="1">
                        <ComboBoxItem x:Name="SortWatchedOldestItem" Tag="watched_oldest" Content="Сначала старые просмотры"/>
                        <ComboBoxItem x:Name="SortWatchedRecentItem" Tag="watched_recent" Content="Сначала новые просмотры"/>
                        <ComboBoxItem x:Name="SortChannelOrderItem" Tag="channel" Content="По порядку канала"/>
                    </ComboBox>

                    <StackPanel Grid.Column="4"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button x:Name="MainMinimizeButton"
                                Style="{StaticResource WindowControlButtonStyle}"
                                Content="&#xE921;"
                                Click="MainMinimizeButton_Click"/>
                        <Button x:Name="MainWindowSizeButton"
                                Margin="8,0,0,0"
                                Style="{StaticResource WindowControlButtonStyle}"
                                Content="&#xE922;"
                                Click="MainWindowSizeButton_Click"/>
                        <Button x:Name="MainCloseButton"
                                Margin="8,0,0,0"
                                Style="{StaticResource WindowCloseButtonStyle}"
                                Content="&#xE8BB;"
                                Click="MainCloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,2,0,0" Height="62">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="HomeNavButton"
                        Grid.Column="0"
                        Style="{StaticResource TopNavButtonStyle}"
                        Content="Главная"
                        Click="HomeNavButton_Click"/>
                <Button x:Name="FavoritesNavButton"
                        Grid.Column="2"
                        Style="{StaticResource TopNavButtonStyle}"
                        Content="Избранное"
                        Click="FavoritesNavButton_Click"/>
                <Button x:Name="ProfileNavButton"
                        Grid.Column="4"
                        Style="{StaticResource TopNavButtonStyle}"
                        Content="Профиль"
                        Click="ProfileNavButton_Click"/>
                <Button x:Name="WatchTogetherNavButton"
                        Grid.Column="6"
                        Style="{StaticResource TopNavButtonStyle}"
                        Content="Watch Together"
                        Click="WatchTogetherNavButton_Click"/>
                <Button x:Name="SettingsNavButton"
                        Grid.Column="8"
                        Style="{StaticResource TopNavButtonStyle}"
                        Content="Настройки"
                        Click="SettingsNavButton_Click"/>
            </Grid>

            <TabControl x:Name="TopTabControl"
                        Grid.Row="2"
                        Margin="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Visibility="Collapsed"
                        SelectionChanged="TopTabControl_SelectionChanged">
                <TabItem Header="Главная"/>
                <TabItem Header="Избранное"/>
                <TabItem Header="Профиль"/>
                <TabItem Header="Задания"/>
                <TabItem Header="Настройки"/>
                <TabItem Header="Watch Together"/>
            </TabControl>

            <Grid Grid.Row="4" Grid.RowSpan="3" Margin="0,12,0,0">
                <Grid.Resources>
                    <LinearGradientBrush x:Key="HomePanelBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#D514202C" Offset="0"/>
                        <GradientStop Color="#D5192837" Offset="0.55"/>
                        <GradientStop Color="#D61C3142" Offset="1"/>
                    </LinearGradientBrush>
                    <Style x:Key="HomeGlassPanelStyle" TargetType="Border">
                        <Setter Property="CornerRadius" Value="18"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="#4E728C"/>
                        <Setter Property="Background" Value="{StaticResource HomePanelBackgroundBrush}"/>
                    </Style>
                    <Style x:Key="HomeInnerGlassStyle" TargetType="Border">
                        <Setter Property="CornerRadius" Value="14"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="#36556D"/>
                        <Setter Property="Background" Value="#A9111922"/>
                    </Style>
                </Grid.Resources>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="RecommendationsColumn" Width="420"/>
                    <ColumnDefinition x:Name="MainColumnsSpacer" Width="16"/>
                    <ColumnDefinition x:Name="StreamsColumn" Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="HomeSummaryPanel"
                        Grid.Row="0"
                        Grid.ColumnSpan="3"
                        Padding="14,10"
                        Style="{StaticResource HomeGlassPanelStyle}">
                    <!-- Hidden compat elements for old code references -->
                    <Border.Resources>
                        <Style TargetType="TextBlock" x:Key="HiddenCompat">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </Style>
                    </Border.Resources>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Streak stat -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="4,0,18,0">
                            <TextBlock x:Name="StatsStreakLabel"
                                       Text="Серия"
                                       Foreground="#6898B5"
                                       FontSize="11"
                                       FontWeight="SemiBold"/>
                            <TextBlock x:Name="StatsStreakText"
                                       Text="0 дн."
                                       Foreground="#F0C070"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Margin="0,1,0,0"/>
                        </StackPanel>

                        <Rectangle Grid.Column="1" Width="1" Height="36" Fill="#2A4A5E" VerticalAlignment="Center"/>

                        <!-- Hours stat -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="18,0">
                            <TextBlock x:Name="StatsTotalHoursLabel"
                                       Text="Часов просмотра"
                                       Foreground="#6898B5"
                                       FontSize="11"
                                       FontWeight="SemiBold"/>
                            <TextBlock x:Name="StatsTotalHoursText"
                                       Text="0.0 ч"
                                       Foreground="#C4E8FF"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Margin="0,1,0,0"/>
                        </StackPanel>

                        <Rectangle Grid.Column="3" Width="1" Height="36" Fill="#2A4A5E" VerticalAlignment="Center"/>

                        <!-- Stream count stat -->
                        <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="18,0">
                            <TextBlock x:Name="StatsStreamCountLabel"
                                       Text="Стримов в каталоге"
                                       Foreground="#6898B5"
                                       FontSize="11"
                                       FontWeight="SemiBold"/>
                            <TextBlock x:Name="StatsStreamCountText"
                                       Text="0"
                                       Foreground="#C4E8FF"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Margin="0,1,0,0"/>
                        </StackPanel>

                        <Rectangle Grid.Column="5" Width="1" Height="36" Fill="#2A4A5E" VerticalAlignment="Center"/>

                        <!-- XP / Level widget -->
                        <StackPanel Grid.Column="6" VerticalAlignment="Center" Margin="18,0,4,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="StatsLevelText"
                                           Text="Уровень 1"
                                           Foreground="#C4E8FF"
                                           FontSize="14"
                                           FontWeight="Bold"/>
                                <TextBlock x:Name="StatsXpText"
                                           Grid.Column="1"
                                           Text="0 / 0 XP"
                                           Foreground="#7AAEC8"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <ProgressBar x:Name="StatsXpBar"
                                         Margin="0,5,0,0"
                                         Height="6"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="0"
                                         Background="#1A344A"
                                         BorderBrush="#2A4A5E"
                                         BorderThickness="1"/>
                        </StackPanel>

                        <!-- Hidden compatibility elements -->
                        <TextBlock x:Name="HomeOverviewHeaderText" Visibility="Collapsed"/>
                        <TextBlock x:Name="HomeStatsText" Visibility="Collapsed"/>
                        <TextBlock x:Name="HomeHintText" Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <Border x:Name="FavoritesSummaryPanel"
                        Grid.Row="0"
                        Grid.ColumnSpan="3"
                        Padding="18,16"
                        Visibility="Collapsed"
                        Style="{StaticResource HomeGlassPanelStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,18,0">
                            <TextBlock x:Name="FavoritesOverviewHeaderText"
                                       Text="Избранное без шума"
                                       Foreground="#EEF8FF"
                                       FontSize="24"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="FavoritesOverviewSubText"
                                       Margin="0,5,0,0"
                                       Text="Быстрый доступ к любимым стримам и сохранённым моментам."
                                       Foreground="#8EB8D4"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Padding="12,10"
                                        CornerRadius="14"
                                        Background="#B0152636"
                                        BorderBrush="#3F607B"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock x:Name="FavoritesFavoriteCountLabelText"
                                                   Text="Избранные стримы"
                                                   Foreground="#77A6C3"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="FavoritesFavoriteCountValueText"
                                                   Text="0"
                                                   Foreground="#F0F8FF"
                                                   FontSize="28"
                                                   FontWeight="Bold"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Padding="12,10"
                                        CornerRadius="14"
                                        Background="#B0192538"
                                        BorderBrush="#4B6D8B"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock x:Name="FavoritesMomentCountLabelText"
                                                   Text="Сохранённые моменты"
                                                   Foreground="#7BB0D1"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="FavoritesMomentCountValueText"
                                                   Text="0"
                                                   Foreground="#97D8FF"
                                                   FontSize="28"
                                                   FontWeight="Bold"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="4"
                                        Padding="12,10"
                                        CornerRadius="14"
                                        Background="#B0222A39"
                                        BorderBrush="#5B7590"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock x:Name="FavoritesResumeCountLabelText"
                                                   Text="Готовы к продолжению"
                                                   Foreground="#8CB7D1"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="FavoritesResumeCountValueText"
                                                   Text="0"
                                                   Foreground="#E9F3FF"
                                                   FontSize="28"
                                                   FontWeight="Bold"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="6"
                                        Padding="12,10"
                                        CornerRadius="14"
                                        Background="#B0282434"
                                        BorderBrush="#6B7394"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock x:Name="FavoritesStreamsWithMomentsLabelText"
                                                   Text="Стримы с таймкодами"
                                                   Foreground="#95B7DE"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="FavoritesStreamsWithMomentsValueText"
                                                   Text="0"
                                                   Foreground="#F6D998"
                                                   FontSize="28"
                                                   FontWeight="Bold"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Width="260"
                                    VerticalAlignment="Stretch">
                            <Button x:Name="ResumeFavoriteButton"
                                    Margin="0,0,0,8"
                                    Padding="12,10"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Content="Продолжить лучшее"
                                    Click="ResumeFavoriteButton_Click"/>
                            <Button x:Name="RandomFavoriteMomentButton"
                                    Padding="12,10"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Content="Случайный момент"
                                    Click="RandomFavoriteMomentButton_Click"/>
                            <Border Margin="0,12,0,0"
                                    Padding="12,10"
                                    CornerRadius="12"
                                    Background="#8F111C27"
                                    BorderBrush="#345A73"
                                    BorderThickness="1">
                                <TextBlock x:Name="FavoritesSearchHintText"
                                           Text="Поиск сверху ищет и стримы, и таймкоды."
                                           Foreground="#8FB8D3"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border x:Name="StreamsPanel"
                        Grid.Row="2"
                        Grid.Column="2"
                        Padding="14"
                        Style="{StaticResource HomeGlassPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Twitch open button -->
                        <Button x:Name="TwitchWatchButton"
                                Grid.Row="0"
                                Margin="0,0,0,4"
                                Padding="0,9"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Click="TwitchWatchButton_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="📺" FontSize="15" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TwitchWatchButtonText" Text="Открыть Twitch" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Category filter chips row -->
                        <Border Grid.Row="2"
                                Padding="10,8"
                                Style="{StaticResource HomeInnerGlassStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button x:Name="FilterAllButton"
                                            Content="Все"
                                            Tag="all"
                                            Padding="5,12"
                                            Margin="0,0,6,0"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Background="#1E5060"
                                            BorderBrush="#4a8aaa"
                                            BorderThickness="1"
                                            Foreground="#D4EEFF"
                                            Click="CategoryFilterButton_Click"/>
                                    <Button x:Name="FilterFavoritesButton"
                                            Content="★ Избранное"
                                            Tag="favorites"
                                            Padding="5,12"
                                            Margin="0,0,6,0"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Background="#12202B"
                                            BorderBrush="#2A4A62"
                                            BorderThickness="1"
                                            Foreground="#E8C445"
                                            Click="CategoryFilterButton_Click"/>
                                    <Button x:Name="FilterTimecodesButton"
                                            Content="# Таймкоды"
                                            Tag="with_timecodes"
                                            Padding="5,12"
                                            Margin="0,0,0,0"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Background="#12202B"
                                            BorderBrush="#2A4A62"
                                            BorderThickness="1"
                                            Foreground="#90BEFF"
                                            Click="CategoryFilterButton_Click"/>
                                </StackPanel>

                                <!-- Random stream button -->
                                <Button x:Name="RandomStreamButton"
                                        Grid.Column="1"
                                        Content="&#x1F500; Случайный"
                                        Padding="10,5"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Background="#1A3E55"
                                        BorderBrush="#3A6E88"
                                        BorderThickness="1"
                                        Foreground="#90D6FF"
                                        ToolTip="Открыть случайный стрим из текущего списка"
                                        Click="RandomStreamButton_Click"/>
                            </Grid>
                        </Border>

                        <!-- Stream count indicator -->
                        <TextBlock x:Name="StreamsCountLabel"
                                   Grid.Row="4"
                                   Foreground="#4A7890"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="4,0,0,0"
                                   Text="Загрузка..."/>

                        <!-- Video list -->
                        <Border Grid.Row="6"
                                Padding="8"
                                CornerRadius="14"
                                BorderBrush="#34546B"
                                BorderThickness="1"
                                Background="#99101923">
                            <ListBox x:Name="VideoList"
                                     Margin="0,2,6,2"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.CanContentScroll="True"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.ScrollUnit="Pixel"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     ItemContainerStyle="{StaticResource VideoItemStyle}"
                                     SelectionChanged="VideoList_SelectionChanged">
                                <ListBox.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource UnifiedScrollBarStyle}"/>
                                </ListBox.Resources>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3"/>
                                                <ColumnDefinition Width="162"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="28"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Left accent bar — colored when in-progress -->
                                            <Border Grid.Column="0"
                                                    CornerRadius="2,0,0,2"
                                                    VerticalAlignment="Stretch">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1E4060"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasResumePosition}" Value="True">
                                                                <Setter Property="Background" Value="#2A7AA0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>

                                            <!-- Thumbnail with overlaid badges -->
                                            <Border Grid.Column="1"
                                                    Width="162"
                                                    Height="92"
                                                    CornerRadius="8"
                                                    Background="#A41A2838"
                                                    BorderBrush="#2A4A62"
                                                    BorderThickness="1"
                                                    ClipToBounds="True"
                                                    VerticalAlignment="Top">
                                                <Grid>
                                                    <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill"/>
                                                    <Border Background="#15081116"/>

                                                    <!-- Progress bar at bottom of thumbnail -->
                                                    <Border VerticalAlignment="Bottom"
                                                            Height="3"
                                                            Background="#1A344A"
                                                            Opacity="0.7">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasResumePosition}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                    <Rectangle VerticalAlignment="Bottom"
                                                               Height="3"
                                                               Fill="#4ab8e0"
                                                               HorizontalAlignment="Left"
                                                               Width="{Binding ResumeBarWidth}">
                                                        <Rectangle.Style>
                                                            <Style TargetType="Rectangle">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasResumePosition}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Rectangle.Style>
                                                    </Rectangle>

                                                    <!-- Badges overlay -->
                                                    <StackPanel Orientation="Horizontal"
                                                                VerticalAlignment="Top"
                                                                HorizontalAlignment="Left"
                                                                Margin="4,4,0,0">
                                                        <!-- Resume badge -->
                                                        <Border CornerRadius="4"
                                                                Padding="3,2"
                                                                Margin="0,0,3,0"
                                                                Background="#CC1A4A6A"
                                                                BorderBrush="#557AC8E8"
                                                                BorderThickness="1">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasResumePosition}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="▶"
                                                                       Foreground="#7AC8E8"
                                                                       FontSize="9"
                                                                       FontWeight="Bold"/>
                                                        </Border>
                                                        <!-- Favorite badge -->
                                                        <Border CornerRadius="4"
                                                                Padding="3,2"
                                                                Margin="0,0,3,0"
                                                                Background="#CC7A5A10"
                                                                BorderBrush="#55F0C04A"
                                                                BorderThickness="1">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="★"
                                                                       Foreground="#F0C04A"
                                                                       FontSize="9"
                                                                       FontWeight="Bold"/>
                                                        </Border>
                                                        <!-- Timecode badge -->
                                                        <Border CornerRadius="4"
                                                                Padding="3,2"
                                                                Background="#CC103050"
                                                                BorderBrush="#554A8AFF"
                                                                BorderThickness="1">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasTimecodes}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding TimecodeCount, StringFormat='🔖{0}'}"
                                                                       Foreground="#9AB8FF"
                                                                       FontSize="9"
                                                                       FontWeight="Bold"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- Info text -->
                                            <StackPanel Grid.Column="3" Margin="0,2,4,0" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="#EEF6FF"
                                                           FontWeight="Bold"
                                                           FontSize="17"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="68"/>
                                                <TextBlock Text="{Binding PublishedAtText}"
                                                           Foreground="#6898B5"
                                                           FontSize="13"
                                                           Margin="0,5,0,0"/>
                                                <TextBlock Text="{Binding LastViewedText}"
                                                           Foreground="#527E97"
                                                           FontSize="13"
                                                           Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding ResumeText}"
                                                           Foreground="#86B6CE"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Queue button -->
                                            <Button Grid.Column="4"
                                                    Width="28"
                                                    Height="28"
                                                    Padding="0"
                                                    FontSize="13"
                                                    FontWeight="Bold"
                                                    Background="Transparent"
                                                    BorderBrush="#334D65"
                                                    BorderThickness="1"
                                                    Foreground="#70A8C8"
                                                    Content="+"
                                                    Tag="{Binding VideoId}"
                                                    ToolTip="Добавить в очередь"
                                                    VerticalAlignment="Top"
                                                    Margin="0,2,0,0"
                                                    Click="AddToQueueButton_Click"/>

                                            <!-- Favorite button -->
                                            <Button Grid.Column="6"
                                                    Width="28"
                                                    Height="28"
                                                    Padding="0"
                                                    FontSize="14"
                                                    FontWeight="Bold"
                                                    Background="Transparent"
                                                    BorderBrush="#334D65"
                                                    BorderThickness="1"
                                                    Foreground="#E8C445"
                                                    Content="{Binding FavoriteGlyph}"
                                                    Tag="{Binding VideoId}"
                                                    ToolTip="Переключить избранное"
                                                    VerticalAlignment="Top"
                                                    Margin="0,2,0,0"
                                                    Click="ToggleFavoriteButton_Click"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="RecommendationsPanel"
                        Grid.Row="2"
                        Grid.Column="0"
                        Padding="14"
                        Style="{StaticResource HomeGlassPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>   <!-- Continue Watching -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>   <!-- Watch Queue -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>      <!-- Recommendations -->
                        </Grid.RowDefinitions>

                        <!-- ── Continue Watching ── -->
                        <Border x:Name="ContinueWatchingSection"
                                Grid.Row="0"
                                Background="#B3192E43"
                                BorderBrush="#44657E96"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,10"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="ContinueWatchingHeaderText"
                                           Text="Продолжить просмотр"
                                           Foreground="#D6EEFF"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Margin="0,0,0,8"/>
                                <ListBox x:Name="ContinueWatchingList"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                         ItemContainerStyle="{StaticResource VideoItemStyle}"
                                         SelectionChanged="ContinueWatchingList_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="80" Height="46"
                                                        CornerRadius="6"
                                                        Background="#A41A2838"
                                                        BorderBrush="#2A4A62"
                                                        BorderThickness="1"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill"/>
                                                        <!-- Resume bar -->
                                                        <Border VerticalAlignment="Bottom" Height="3" Background="#1A344A" Opacity="0.7"/>
                                                        <Rectangle VerticalAlignment="Bottom"
                                                                   Height="3"
                                                                   Fill="#4ab8e0"
                                                                   HorizontalAlignment="Left"
                                                                   Width="{Binding ResumeBarWidthSmall}"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="#EEF6FF"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="36"/>
                                                    <TextBlock Text="{Binding ResumeText}"
                                                               Foreground="#4ab8e0"
                                                               FontSize="11"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <!-- ── Watch Queue ── -->
                        <Border x:Name="WatchQueueSection"
                                Grid.Row="2"
                                Background="#B3192E43"
                                BorderBrush="#44657E96"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,10"
                                Visibility="Collapsed">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock x:Name="WatchQueueHeaderText"
                                                   Text="Очередь"
                                                   Foreground="#D6EEFF"
                                                   FontSize="14"
                                                   FontWeight="Bold"/>
                                        <Border x:Name="WatchQueueBadge"
                                                Margin="6,0,0,0"
                                                Padding="5,1"
                                                CornerRadius="8"
                                                Background="#2A5F7E"
                                                VerticalAlignment="Center">
                                            <TextBlock x:Name="WatchQueueCountText"
                                                       Text="0"
                                                       Foreground="#90D6FF"
                                                       FontSize="11"
                                                       FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                    <Button x:Name="PlayQueueButton"
                                            Grid.Column="1"
                                            Content="▶ Смотреть всё"
                                            Padding="8,4"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Background="#1A4A60"
                                            BorderBrush="#3A7A98"
                                            BorderThickness="1"
                                            Foreground="#90D6FF"
                                            Click="PlayQueueButton_Click"/>
                                </Grid>
                                <ListBox x:Name="WatchQueueList"
                                         MaxHeight="160"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ItemContainerStyle="{StaticResource VideoItemStyle}">
                                    <ListBox.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource UnifiedScrollBarStyle}"/>
                                    </ListBox.Resources>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="#C8E4F4"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="36"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1"
                                                        Width="22"
                                                        Height="22"
                                                        Padding="0"
                                                        FontSize="12"
                                                        Background="Transparent"
                                                        BorderBrush="#334D65"
                                                        BorderThickness="1"
                                                        Foreground="#8098B0"
                                                        Content="✕"
                                                        Tag="{Binding VideoId}"
                                                        VerticalAlignment="Center"
                                                        Click="RemoveFromQueueButton_Click"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <!-- ── Recommendations ── -->
                        <Border Grid.Row="4"
                                Background="#B3192E43"
                                BorderBrush="#44657E96"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="RecommendationsHeaderText"
                                           Text="Рекомендации"
                                           Foreground="#D6EEFF"
                                           FontSize="14"
                                           FontWeight="Bold"/>
                                <Border Grid.Row="2"
                                        Padding="4"
                                        CornerRadius="10"
                                        BorderBrush="#34546B"
                                        BorderThickness="1"
                                        Background="#99101923">
                                    <ListBox x:Name="RecommendationsList"
                                             Margin="0,2,4,2"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="#EAD0BF"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.CanContentScroll="True"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Recycling"
                                             ItemContainerStyle="{StaticResource VideoItemStyle}"
                                             SelectionChanged="RecommendationsList_SelectionChanged">
                                        <ListBox.Resources>
                                            <Style TargetType="ScrollBar" BasedOn="{StaticResource UnifiedScrollBarStyle}"/>
                                        </ListBox.Resources>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="100" Height="58"
                                                            CornerRadius="6"
                                                            Background="#A41A2838"
                                                            BorderBrush="#2A4A62"
                                                            BorderThickness="1"
                                                            ClipToBounds="True"
                                                            VerticalAlignment="Top">
                                                        <Grid>
                                                            <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill"/>
                                                            <Border Background="#15081116"/>
                                                        </Grid>
                                                    </Border>
                                                    <StackPanel Grid.Column="2" Margin="0,0,2,0">
                                                        <TextBlock Text="{Binding Title}"
                                                                   Foreground="#EEF6FF"
                                                                   FontWeight="Bold"
                                                                   FontSize="13"
                                                                   TextWrapping="Wrap"
                                                                   MaxHeight="48"/>
                                                        <TextBlock Text="{Binding PublishedAtText}"
                                                                   Foreground="#567A92"
                                                                   FontSize="11"
                                                                   Margin="0,3,0,0"/>
                                                        <TextBlock Text="{Binding LastViewedText}"
                                                                   Foreground="#447090"
                                                                   FontSize="11"
                                                                   Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Favorites: Saved clips panel (shown in place of Recommendations when Favorites tab is active) -->
                <Border x:Name="FavoritesClipsPanel"
                        Grid.Row="2"
                        Grid.Column="0"
                        Padding="14"
                        Visibility="Collapsed"
                        Style="{StaticResource HomeGlassPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="FavoritesClipsHeaderText"
                                       Text="Сохранённые клипы"
                                       Foreground="#EDF7FF"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="FavoritesClipsSubtitleText"
                                       Margin="0,24,0,0"
                                       Foreground="#86ABC4"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Top"/>
                            <TextBlock x:Name="FavoritesClipsCountText"
                                       Grid.Column="1"
                                       Foreground="#4A7890"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </Grid>

                        <!-- Clips list -->
                        <Border Grid.Row="2"
                                Padding="6"
                                CornerRadius="14"
                                BorderBrush="#34546B"
                                BorderThickness="1"
                                Background="#99101923">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <TextBlock x:Name="FavoritesClipsEmptyText"
                                               Text="Нет сохранённых клипов. Открой видео и нажми M."
                                               Foreground="#8FAFC8"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               Margin="4,4,4,0"
                                               Visibility="Collapsed"/>
                                    <ItemsControl x:Name="FavoritesClipsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,6"
                                                        CornerRadius="9"
                                                        Background="#B0142233"
                                                        BorderBrush="#33607A8A"
                                                        BorderThickness="1"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Thumbnail with time badge -->
                                                        <Grid Width="80" Height="48" Background="#0A1820">
                                                            <Image Source="{Binding ThumbnailUrl}"
                                                                   Stretch="UniformToFill"/>
                                                            <Border VerticalAlignment="Bottom"
                                                                    HorizontalAlignment="Right"
                                                                    Margin="0,0,3,3"
                                                                    Padding="3,1"
                                                                    Background="#CC000000"
                                                                    CornerRadius="3">
                                                                <TextBlock Text="{Binding TimeFormatted}"
                                                                           Foreground="#F0FAFF"
                                                                           FontSize="9"
                                                                           FontWeight="Bold"/>
                                                            </Border>
                                                        </Grid>

                                                        <!-- Clip info -->
                                                        <Grid Grid.Column="1" Margin="7,5,6,5">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <TextBlock Grid.Row="0"
                                                                       Text="{Binding VideoTitle}"
                                                                       FontSize="10"
                                                                       Foreground="#5B92B2"
                                                                       TextTrimming="CharacterEllipsis"/>

                                                            <TextBlock Grid.Row="1"
                                                                       Text="{Binding Label}"
                                                                       Foreground="#EDF7FF"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"/>

                                                            <!-- Action row -->
                                                            <StackPanel Grid.Row="2"
                                                                        Orientation="Horizontal"
                                                                        HorizontalAlignment="Right"
                                                                        Margin="0,4,0,0">
                                                                <Button Content="▶"
                                                                        Padding="5,2"
                                                                        FontSize="10"
                                                                        Margin="0,0,4,0"
                                                                        Tag="{Binding Id}"
                                                                        ToolTip="Открыть видео в этом месте"
                                                                        Click="FavoritesClipOpenButton_Click"/>
                                                                <Button Content="✕"
                                                                        Padding="5,2"
                                                                        FontSize="10"
                                                                        Tag="{Binding Id}"
                                                                        Click="FavoritesClipDeleteButton_Click"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border x:Name="ProfilePanel"
                    Grid.Row="4"
                    Grid.RowSpan="3"
                    Padding="14"
                    CornerRadius="18"
                    Background="#D3172431"
                    BorderBrush="#4D728C"
                    BorderThickness="1"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#B3192E43" BorderBrush="#44657E96" BorderThickness="1" CornerRadius="14" Padding="16,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Prestige circle -->
                            <Grid Width="80" Height="80" VerticalAlignment="Center">
                                <Border Background="#2A4460"
                                        BorderBrush="#6090B0"
                                        BorderThickness="2"
                                        CornerRadius="40"
                                        ClipToBounds="True">
                                    <Image x:Name="PrestigeIconImage" Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock x:Name="PrestigeValueText"
                                           FontSize="26"
                                           FontWeight="ExtraBold"
                                           Foreground="#FFF5D8"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Stats -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="ProfileHeaderText" Text="Профиль" Foreground="#D6EEFF" FontWeight="Bold" FontSize="22"/>
                                    <TextBlock x:Name="ProfileLevelText" Grid.Column="1" Margin="14,0,0,0" Foreground="#C8D8E8" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock x:Name="ProfileXpText" Foreground="#8AAAC0" FontSize="14" Margin="0,4,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock x:Name="ProfileStreakText" Foreground="#F0C070" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock x:Name="ProfileTodayText" Foreground="#90B8D0" FontSize="14" Margin="14,0,0,0"/>
                                    <TextBlock x:Name="ProfileHoursText" Foreground="#7AA0B8" FontSize="14" Margin="14,0,0,0"/>
                                </StackPanel>
                                <ProgressBar x:Name="ProfileXpProgress" Margin="0,10,0,0" Height="16" Minimum="0"/>
                            </StackPanel>

                            <!-- Quests button -->
                            <Button x:Name="OpenQuestsButton"
                                    Grid.Column="3"
                                    Background="#2A5F7E"
                                    Foreground="#E8F6FF"
                                    Padding="18,10"
                                    MinHeight="40"
                                    VerticalAlignment="Center"
                                    Content="Открыть задания"
                                    Click="OpenQuestsButton_Click"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#B3192E43" BorderBrush="#44657E96" BorderThickness="1" CornerRadius="14" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="AchievementsHeaderText" Text="Достижения" Foreground="#D6EEFF" FontWeight="Bold" FontSize="18"/>
                                <ListBox x:Name="AchievementsList"
                                          Grid.Row="1"
                                          Margin="0,12,0,0"
                                          Background="Transparent"
                                          Foreground="#EAD0BF"
                                          BorderThickness="0"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          ScrollViewer.CanContentScroll="True"
                                           VirtualizingPanel.IsVirtualizing="True"
                                           VirtualizingPanel.VirtualizationMode="Recycling"
                                           ItemContainerStyle="{StaticResource AchievementItemStyle}"
                                           ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource UnifiedScrollBarStyle}"/>
                                    </ListBox.Resources>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="44"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Width="40"
                                                        Height="40"
                                                        CornerRadius="20"
                                                        BorderBrush="#8AAAC0"
                                                        BorderThickness="1"
                                                        Background="#C63A5468">
                                                    <TextBlock x:Name="AchievementGlyph"
                                                               Text="○"
                                                               FontSize="24"
                                                               FontWeight="Bold"
                                                               Foreground="#D6E8F5"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="#F2FAFF"
                                                               FontWeight="Bold"
                                                               FontSize="20"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="#D2E3EF"
                                                               FontSize="15"
                                                               Margin="0,2,0,0"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsUnlocked}" Value="True">
                                                    <Setter TargetName="AchievementGlyph" Property="Text" Value="✔"/>
                                                    <Setter TargetName="AchievementGlyph" Property="Foreground" Value="#82EDB9"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="#B3192E43" BorderBrush="#44657E96" BorderThickness="1" CornerRadius="14" Padding="14">
                            <StackPanel>
                                <TextBlock x:Name="RecentStreamsHeaderText"
                                           Text="Последние просмотренные"
                                           Foreground="#D6EEFF"
                                           FontWeight="Bold"
                                           FontSize="18"/>
                                <ListBox x:Name="RecentStreamsList"
                                         Margin="0,8,0,0"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#EAD0BF"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.CanContentScroll="True"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling"
                                         ItemContainerStyle="{StaticResource VideoItemStyle}"
                                         SelectionChanged="RecentStreamsList_SelectionChanged">
                                    <ListBox.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource UnifiedScrollBarStyle}"/>
                                    </ListBox.Resources>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Width="120"
                                                        Height="68"
                                                        CornerRadius="8"
                                                        Background="#C334485A"
                                                        ClipToBounds="True"
                                                        VerticalAlignment="Top">
                                                    <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill"/>
                                                </Border>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="#F2FAFF"
                                                               FontWeight="Bold"
                                                               FontSize="16"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding LastViewedText}"
                                                               Foreground="#C3DBEA"
                                                               FontSize="13"
                                                               Margin="0,3,0,0"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="QuestsPanel"
                    Grid.Row="4"
                    Grid.RowSpan="3"
                    Padding="14"
                    CornerRadius="18"
                    Background="#D3172431"
                    BorderBrush="#4D728C"
                    BorderThickness="1"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="QuestsPageHeaderText"
                                       Text="Задания"
                                       Foreground="#D6EEFF"
                                       FontSize="22"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="QuestsSummaryText"
                                       Margin="0,4,0,0"
                                       Foreground="#5A8DAA"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button x:Name="BackToProfileButton"
                                Grid.Column="1"
                                Padding="16,8"
                                MinHeight="36"
                                VerticalAlignment="Center"
                                Content="Назад в профиль"
                                Click="BackToProfileButton_Click"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#B3192E43" BorderBrush="#44657E96" BorderThickness="1" CornerRadius="14" Padding="14">
                            <StackPanel>
                                <TextBlock x:Name="QuestsDailyHeaderText" Text="Ежедневные задания" Foreground="#D6EEFF" FontWeight="Bold" FontSize="17"/>
                                <TextBlock x:Name="QuestsDailyResetText"
                                           Margin="0,4,0,0"
                                           Text="Обновление через: --:--:--"
                                           Foreground="#A8D8F2"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                                <ListBox x:Name="QuestsDailyList"
                                         Margin="0,12,0,0"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ItemContainerStyle="{StaticResource QuestItemStyle}">
                                    <ListBox.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource UnifiedScrollBarStyle}"/>
                                    </ListBox.Resources>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding StatusGlyph}" Foreground="{Binding StatusColor}" FontSize="16" VerticalAlignment="Top"/>
                                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding Title}" Foreground="#F4FBFF" FontWeight="Bold" FontSize="16"/>
                                                    <TextBlock Text="{Binding Description}" Foreground="#D3E6F3" FontSize="13" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontSize="13" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                                    <TextBlock Text="{Binding ProgressText}" Foreground="#A9D8F3" FontSize="13" Margin="0,2,0,0"/>
                                                    <TextBlock Text="{Binding RewardText}" Foreground="#9CE6B7" FontSize="13"/>
                                                    <Button Margin="0,6,0,0"
                                                            Height="32"
                                                            HorizontalAlignment="Left"
                                                            Style="{StaticResource ClaimQuestButtonStyle}"
                                                            Content="{Binding ClaimButtonText}"
                                                            Tag="{Binding ClaimKey}"
                                                            IsEnabled="{Binding IsClaimEnabled}"
                                                            Click="ClaimQuestButton_Click"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#B3192E43" BorderBrush="#44657E96" BorderThickness="1" CornerRadius="14" Padding="14">
                            <StackPanel>
                                <TextBlock x:Name="QuestsWeeklyHeaderText" Text="Еженедельные задания" Foreground="#D6EEFF" FontWeight="Bold" FontSize="17"/>
                                <TextBlock x:Name="QuestsWeeklyResetText"
                                           Margin="0,4,0,0"
                                           Text="Обновление через: --:--:--"
                                           Foreground="#A8D8F2"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                                <ListBox x:Name="QuestsWeeklyList"
                                         Margin="0,12,0,0"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ItemContainerStyle="{StaticResource QuestItemStyle}">
                                    <ListBox.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource UnifiedScrollBarStyle}"/>
                                    </ListBox.Resources>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding StatusGlyph}" Foreground="{Binding StatusColor}" FontSize="16" VerticalAlignment="Top"/>
                                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding Title}" Foreground="#F4FBFF" FontWeight="Bold" FontSize="16"/>
                                                    <TextBlock Text="{Binding Description}" Foreground="#D3E6F3" FontSize="13" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontSize="13" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                                    <TextBlock Text="{Binding ProgressText}" Foreground="#A9D8F3" FontSize="13" Margin="0,2,0,0"/>
                                                    <TextBlock Text="{Binding RewardText}" Foreground="#9CE6B7" FontSize="13"/>
                                                    <Button Margin="0,6,0,0"
                                                            Height="32"
                                                            HorizontalAlignment="Left"
                                                            Style="{StaticResource ClaimQuestButtonStyle}"
                                                            Content="{Binding ClaimButtonText}"
                                                            Tag="{Binding ClaimKey}"
                                                            IsEnabled="{Binding IsClaimEnabled}"
                                                            Click="ClaimQuestButton_Click"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="SettingsPanel"
                    Grid.Row="4"
                    Grid.RowSpan="3"
                    Padding="0"
                    CornerRadius="18"
                    Background="#D3172431"
                    BorderBrush="#4D728C"
                    BorderThickness="1"
                    Visibility="Collapsed">
                <Grid Margin="16,14,16,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="SettingsHeaderText"
                                   Grid.Row="0"
                                   Text="Настройки"
                                   Foreground="#EDF7FF"
                                   FontSize="26"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="SettingsSubtitleText"
                                   Grid.Row="1"
                                   Margin="0,2,0,0"
                                   Text="Персонализация и поведение приложения"
                                   Foreground="#7AACCB"
                                   FontSize="13"/>
                        <TextBlock x:Name="SettingsCreatorText"
                                   Grid.Row="0"
                                   Grid.RowSpan="2"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   Text="dragloner"
                                   Foreground="#55AFC5D7"
                                   FontSize="9"
                                   FontWeight="SemiBold"/>
                    </Grid>

                    <!-- Two-column layout -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="370"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ═══ LEFT COLUMN ═══ -->
                        <ScrollViewer Grid.Column="0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>

                                <!-- Card: Интерфейс -->
                                <Border CornerRadius="12"
                                        Background="#B3192E43"
                                        BorderBrush="#44657E96"
                                        BorderThickness="1"
                                        Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="Интерфейс"
                                                   Foreground="#D6EEFF"
                                                   FontSize="14"
                                                   FontWeight="Bold"
/>

                                        <TextBlock x:Name="LanguageLabelText"
                                                   Margin="0,14,0,0"
                                                   Text="Язык"
                                                   Foreground="#88BBDA"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                        <ComboBox x:Name="LanguageComboBox"
                                                  Margin="0,5,0,0"
                                                  SelectionChanged="LanguageComboBox_SelectionChanged">
                                            <ComboBoxItem Tag="ru" Content="Русский"/>
                                            <ComboBoxItem Tag="en" Content="English"/>
                                        </ComboBox>

                                        <TextBlock x:Name="UiScaleLabelText"
                                                   Margin="0,14,0,0"
                                                   Text="Масштаб UI"
                                                   Foreground="#88BBDA"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                        <Grid Margin="0,5,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="54"/>
                                            </Grid.ColumnDefinitions>
                                            <Slider x:Name="UiScaleSlider"
                                                    VerticalAlignment="Center"
                                                    Minimum="0.85"
                                                    Maximum="1.35"
                                                    TickFrequency="0.05"
                                                    IsMoveToPointEnabled="True"
                                                    IsSnapToTickEnabled="False"
                                                    ValueChanged="UiScaleSlider_ValueChanged"/>
                                            <TextBlock x:Name="UiScaleValueText"
                                                       Grid.Column="1"
                                                       Margin="8,0,0,0"
                                                       Foreground="#D8EAF8"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Right"
                                                       Text="1.00x"/>
                                        </Grid>

                                        <CheckBox x:Name="AnimationsEnabledCheckBox"
                                                  Margin="0,12,0,0"
                                                  Foreground="#C8E2F5"
                                                  FontSize="14"
                                                  Content="Плавные анимации интерфейса"
                                                  Checked="AnimationsEnabledCheckBox_Changed"
                                                  Unchecked="AnimationsEnabledCheckBox_Changed"/>
                                    </StackPanel>
                                </Border>

                                <!-- Card: Запуск и поведение -->
                                <Border CornerRadius="12"
                                        Background="#B3192E43"
                                        BorderBrush="#44657E96"
                                        BorderThickness="1"
                                        Padding="16"
                                        Margin="0,10,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Запуск и поведение"
                                                   Foreground="#D6EEFF"
                                                   FontSize="14"
                                                   FontWeight="Bold"
/>

                                        <TextBlock x:Name="AutoStartLabelText"
                                                   Margin="0,14,0,0"
                                                   Text="Автозапуск"
                                                   Foreground="#88BBDA"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                        <CheckBox x:Name="AutoStartCheckBox"
                                                  Margin="0,6,0,0"
                                                  Foreground="#C8E2F5"
                                                  FontSize="14"
                                                  Content="Запускать вместе с Windows"
                                                  Checked="AutoStartCheckBox_Changed"
                                                  Unchecked="AutoStartCheckBox_Changed"/>
                                        <CheckBox x:Name="AutoCheckUpdatesCheckBox"
                                                  Margin="0,9,0,0"
                                                  Foreground="#C8E2F5"
                                                  FontSize="14"
                                                  Content="Проверять обновления при запуске"
                                                  Checked="AutoCheckUpdatesCheckBox_Changed"
                                                  Unchecked="AutoCheckUpdatesCheckBox_Changed"/>

                                        <Border Margin="0,14,0,12" Height="1" Background="#25485E"/>

                                        <TextBlock x:Name="FullscreenBehaviorLabelText"
                                                   Text="Поведение fullscreen"
                                                   Foreground="#88BBDA"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                        <ComboBox x:Name="FullscreenBehaviorComboBox"
                                                  Margin="0,5,0,0"
                                                  SelectionChanged="FullscreenBehaviorComboBox_SelectionChanged">
                                            <ComboBoxItem Tag="auto" Content="Авто: окно следует fullscreen плеера"/>
                                            <ComboBoxItem Tag="windowed" Content="Оставаться в оконном режиме"/>
                                        </ComboBox>
                                        <TextBlock x:Name="FullscreenBehaviorDescriptionText"
                                                   Margin="0,6,0,0"
                                                   Text="Auto: при fullscreen в YouTube окно плеера тоже развернется. Windowed: остаётся обычным."
                                                   Foreground="#5E8EA8"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- Card: Данные и кеш -->
                                <Border CornerRadius="12"
                                        Background="#B3192E43"
                                        BorderBrush="#44657E96"
                                        BorderThickness="1"
                                        Padding="16"
                                        Margin="0,10,0,0">
                                    <StackPanel>
                                        <TextBlock x:Name="CacheLabelText"
                                                   Text="Данные и кеш"
                                                   Foreground="#D6EEFF"
                                                   FontSize="14"
                                                   FontWeight="Bold"
/>
                                        <TextBlock x:Name="CacheDescriptionText"
                                                   Margin="0,8,0,0"
                                                   Text="Очищает WebView2 профиль (YouTube данные) и временные обновления."
                                                   Foreground="#5E8EA8"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="ResetCacheButton"
                                                    Grid.Column="0"
                                                    MinHeight="36"
                                                    FontSize="13"
                                                    Content="Сбросить кеш"
                                                    Click="ResetCacheButton_Click"/>
                                            <Button x:Name="OpenLogFolderButton"
                                                    Grid.Column="2"
                                                    MinHeight="36"
                                                    FontSize="13"
                                                    Content="Открыть логи"
                                                    Click="OpenLogFolderButton_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>

                        <!-- ═══ RIGHT COLUMN ═══ -->
                        <ScrollViewer Grid.Column="2"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>

                                <!-- Card: Плеер и бинды -->
                                <Border CornerRadius="12"
                                        Background="#B3192E43"
                                        BorderBrush="#44657E96"
                                        BorderThickness="1"
                                        Padding="16">
                                    <StackPanel>
                                        <TextBlock x:Name="BindsSectionTitleText"
                                                   Text="Бинды плеера"
                                                   Foreground="#D6EEFF"
                                                   FontSize="14"
                                                   FontWeight="Bold"/>
                                        <TextBlock x:Name="BindsSectionDescriptionText"
                                                   Margin="0,4,0,0"
                                                   Text="Клавиши для панели эффектов, всех 15 эффектов и саунд-эффектов."
                                                   Foreground="#5E8EA8"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>

                                        <!-- Capture hint + live status -->
                                        <Border Margin="0,10,0,0" Padding="10,7"
                                                Background="#0D1F2D" CornerRadius="8"
                                                BorderBrush="#2A4F68" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock x:Name="BindCaptureHelpText"
                                                           Text="Нажмите «Назначить», затем любую клавишу. Esc — отмена."
                                                           Foreground="#6EB0D4"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock x:Name="BindCaptureStatusText"
                                                           Text=""
                                                           Margin="0,3,0,0"
                                                           Foreground="#F4D89B"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Sound spam mode -->
                                        <Border Margin="0,14,0,0" Height="1" Background="#25485E"/>
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock x:Name="SoundModeHeaderText"
                                                           Text="Режим звуковых эффектов"
                                                           Foreground="#C8E2F5"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock x:Name="SoundModeDescText"
                                                           Margin="0,3,0,0"
                                                           Text="Выкл — стоп при повторном нажатии. Вкл — спам до 8 звуков."
                                                           Foreground="#5E8EA8"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <CheckBox x:Name="SoundSpamModeToggle"
                                                      Grid.Column="1"
                                                      Margin="16,0,0,0"
                                                      VerticalAlignment="Center"
                                                      Foreground="#C8E2F5"
                                                      FontSize="13"
                                                      Checked="SoundSpamModeToggle_Changed"
                                                      Unchecked="SoundSpamModeToggle_Changed"/>
                                        </Grid>

                                        <!-- EQ for sound effects -->
                                        <Border Margin="0,12,0,0" Height="1" Background="#25485E"/>
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock x:Name="EqForSoundFxHeaderText"
                                                           Text="Эквалайзер для звуковых эффектов"
                                                           Foreground="#C8E2F5"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock x:Name="EqForSoundFxDescText"
                                                           Margin="0,3,0,0"
                                                           Text="Применять настройки эквалайзера плеера к звуковым эффектам."
                                                           Foreground="#5E8EA8"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <CheckBox x:Name="ApplyEqToSoundEffectsCheckBox"
                                                      Grid.Column="1"
                                                      Margin="16,0,0,0"
                                                      VerticalAlignment="Center"
                                                      Foreground="#C8E2F5"
                                                      FontSize="13"
                                                      Checked="ApplyEqToSoundEffectsCheckBox_Changed"
                                                      Unchecked="ApplyEqToSoundEffectsCheckBox_Changed"/>
                                        </Grid>

                                        <!-- Utility + Sound binds -->
                                        <Border Margin="0,14,0,0" Height="1" Background="#25485E"/>
                                        <TextBlock Margin="0,12,0,4"
                                                   Text="Клавиши звуков и панели"
                                                   Foreground="#88BBDA"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>

                                        <!-- HideEffects -->
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="56"/>
                                                <ColumnDefinition Width="92"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="HideEffectsBindLabelText"
                                                       Text="Скрыть/показать эффекты"
                                                       Foreground="#C8E2F5" FontSize="12"
                                                       VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" Margin="6,0" Padding="6,3"
                                                    CornerRadius="6" BorderBrush="#44819DB8"
                                                    BorderThickness="1" Background="#AA192E43">
                                                <TextBlock x:Name="HideEffectsPanelBindValueText"
                                                           Text="H" Foreground="#F3FBFF"
                                                           FontWeight="Bold" FontSize="12"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                            <Button x:Name="AssignHideEffectsBindButton"
                                                    Grid.Column="2" Padding="6,4" FontSize="11"
                                                    Content="Назначить" Tag="hide_effects"
                                                    Click="AssignBindButton_Click"/>
                                        </Grid>

                                        <!-- ToggleChat -->
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="56"/>
                                                <ColumnDefinition Width="92"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Чат слева (вкл/выкл)"
                                                       Foreground="#C8E2F5" FontSize="12"
                                                       VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" Margin="6,0" Padding="6,3"
                                                    CornerRadius="6" BorderBrush="#44819DB8"
                                                    BorderThickness="1" Background="#AA192E43">
                                                <TextBlock x:Name="ToggleChatBindValueText"
                                                           Text="-" Foreground="#F3FBFF"
                                                           FontWeight="Bold" FontSize="12"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                            <Button x:Name="AssignToggleChatBindButton"
                                                    Grid.Column="2" Padding="6,4" FontSize="11"
                                                    Content="Назначить" Tag="toggle_chat"
                                                    Click="AssignBindButton_Click"/>
                                        </Grid>

                                        <!-- ToggleComments -->
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="56"/>
                                                <ColumnDefinition Width="92"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Комментарии снизу (вкл/выкл)"
                                                       Foreground="#C8E2F5" FontSize="12"
                                                       VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" Margin="6,0" Padding="6,3"
                                                    CornerRadius="6" BorderBrush="#44819DB8"
                                                    BorderThickness="1" Background="#AA192E43">
                                                <TextBlock x:Name="ToggleCommentsBindValueText"
                                                           Text="-" Foreground="#F3FBFF"
                                                           FontWeight="Bold" FontSize="12"
