                                         Margin="0,5,0,0"
                                         Text="7777"
                                         FontSize="16"
                                         FontWeight="SemiBold"
                                         MaxLength="5"
                                         Width="110"
                                         HorizontalAlignment="Left"/>

                                <Button x:Name="WtHostButton"
                                        Margin="0,14,0,0"
                                        MinHeight="44"
                                        Content="Создать комнату (Хост)"
                                        FontSize="15"
                                        FontWeight="Bold"
                                        Click="WtHostButton_Click"/>

                                <Border Margin="0,14,0,0" Height="1" Background="#25485E"/>

                                <TextBlock x:Name="WtIpLabelText"
                                           Margin="0,14,0,0"
                                           Text="IP адрес хоста"
                                           Foreground="#88BBDA"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                                <TextBox x:Name="WtIpBox"
                                         Margin="0,5,0,0"
                                         FontSize="16"
                                         FontWeight="SemiBold"
                                         MaxLength="45"/>

                                <Button x:Name="WtConnectButton"
                                        Margin="0,14,0,0"
                                        MinHeight="44"
                                        Content="Подключиться (Гость)"
                                        FontSize="15"
                                        FontWeight="Bold"
                                        Click="WtConnectButton_Click"/>

                                <Button x:Name="WtDisconnectButton"
                                        Margin="0,10,0,0"
                                        MinHeight="40"
                                        Content="Отключиться"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Visibility="Collapsed"
                                        Click="WtDisconnectButton_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Right: Status & Info card -->
                        <Border Grid.Column="2"
                                CornerRadius="12"
                                BorderBrush="#44657E96"
                                BorderThickness="1"
                                Padding="16"
                                Background="#B3192E43">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <TextBlock x:Name="WtStatusHeaderText"
                                           Text="Статус сервера"
                                           Foreground="#D6EEFF"
                                           FontSize="16"
                                           FontWeight="Bold"/>

                                <Border Margin="0,10,0,0"
                                        Padding="14"
                                        CornerRadius="10"
                                        BorderBrush="#33506070"
                                        BorderThickness="1"
                                        Background="#881A2A3A">
                                    <StackPanel>
                                        <TextBlock x:Name="WtStatusText"
                                                   Text="● Сервер не запущен"
                                                   Foreground="#E8B85A"
                                                   FontSize="16"
                                                   FontWeight="Bold"/>
                                        <TextBlock x:Name="WtRoleText"
                                                   Margin="0,6,0,0"
                                                   Text=""
                                                   Foreground="#C8E2F5"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="WtPortInfoText"
                                                   Margin="0,4,0,0"
                                                   Text=""
                                                   Foreground="#7AACCB"
                                                   FontSize="13"/>
                                    </StackPanel>
                                </Border>

                                <!-- Host IP block -->
                                <Border x:Name="WtHostIpPanel"
                                        Margin="0,10,0,0"
                                        Padding="14"
                                        CornerRadius="10"
                                        Background="#12243444"
                                        BorderBrush="#44709ABB"
                                        BorderThickness="1"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock x:Name="WtMyIpHeaderText"
                                                   Text="Скажи другу этот IP:"
                                                   Foreground="#5ABCE8"
                                                   FontSize="13"
                                                   FontWeight="Bold"/>
                                        <TextBlock x:Name="WtMyIpText"
                                                   Margin="0,6,0,0"
                                                   Text=""
                                                   Foreground="#F3FBFF"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock x:Name="WtMyIpHintText"
                                                   Margin="0,4,0,0"
                                                   Text="Друг должен ввести этот IP в поле «IP адрес хоста» и нажать «Подключиться»."
                                                   Foreground="#507A94"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- Connected peers list -->
                                <Border x:Name="WtPeersPanel"
                                        Margin="0,10,0,0"
                                        Padding="14"
                                        CornerRadius="10"
                                        BorderBrush="#33506070"
                                        BorderThickness="1"
                                        Background="#881A2A3A"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock x:Name="WtPeersHeaderText"
                                                   Text="Подключённые участники"
                                                   Foreground="#D6EEFF"
                                                   FontSize="14"
                                                   FontWeight="Bold"/>
                                        <TextBlock x:Name="WtPeersCountText"
                                                   Margin="0,4,0,0"
                                                   Text=""
                                                   Foreground="#7AACCB"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"/>
                                        <Border Margin="0,8,0,0"
                                                Padding="10"
                                                CornerRadius="8"
                                                Background="#0E1C27">
                                            <TextBlock x:Name="WtPeersListText"
                                                       Text=""
                                                       Foreground="#C8E2F5"
                                                       FontSize="14"
                                                       TextWrapping="Wrap"
                                                       FontFamily="Consolas"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Guest connected-to info -->
                                <Border x:Name="WtGuestInfoPanel"
                                        Margin="0,10,0,0"
                                        Padding="14"
                                        CornerRadius="10"
                                        BorderBrush="#3370A060"
                                        BorderThickness="1"
                                        Background="#881A2A3A"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock x:Name="WtGuestConnectedText"
                                                   Text="Подключено к хосту"
                                                   Foreground="#5AE880"
                                                   FontSize="14"
                                                   FontWeight="Bold"/>
                                        <TextBlock x:Name="WtGuestHostAddrText"
                                                   Margin="0,4,0,0"
                                                   Text=""
                                                   Foreground="#C8E2F5"
                                                   FontSize="13"/>
                                        <TextBlock x:Name="WtGuestSyncHintText"
                                                   Margin="0,6,0,0"
                                                   Text="Ожидайте — хост откроет видео и управление будет синхронизировано."
                                                   Foreground="#507A94"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- Instructions (shown when not connected) -->
                                <Border x:Name="WtInstructionsPanel"
                                        Margin="0,14,0,0">
                                    <StackPanel>
                                        <TextBlock x:Name="WtInfoHeaderText"
                                                   Text="Как это работает"
                                                   Foreground="#88BBDA"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="WtInfoText"
                                                   Margin="0,8,0,0"
                                                   Foreground="#507A94"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   Text="1. Оба игрока запускают Radmin VPN и подключаются к одной сети.&#x0a;2. Один игрок нажимает «Создать комнату» — он становится хостом.&#x0a;3. Второй игрок вводит IP хоста (из Radmin VPN) и нажимает «Подключиться».&#x0a;4. Хост открывает видео — оно автоматически откроется у гостя.&#x0a;5. Play, pause и перемотка синхронизируются автоматически."/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <TextBlock x:Name="StatusText" Grid.Row="8" Visibility="Collapsed"/>

            <Grid x:Name="LoadingOverlay"
                  Grid.RowSpan="9"
                  Panel.ZIndex="1000"
                  Margin="-28"
                  ClipToBounds="True"
                  Background="#0B141D">
                <Image x:Name="LoadingBackgroundImage"
                        Stretch="UniformToFill"
                       Opacity="1.0"/>
                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Width="760">
                    <Border Padding="24,22"
                            CornerRadius="18"
                            BorderBrush="#78C7E6FA"
                            BorderThickness="1"
                            Background="#D61D2731">
                        <StackPanel>
                            <TextBlock Text="JokerDBD Tracker"
                                       Foreground="#F8FCFF"
                                       FontSize="50"
                                       FontWeight="ExtraBold"
                                       TextOptions.TextFormattingMode="Display"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="5" ShadowDepth="0" Color="#0C151E" Opacity="1"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock x:Name="LoadingTitleText"
                                       Text="Загрузка приложения"
                                       Margin="0,6,0,0"
                                       Foreground="#E8F4FC"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#0E1A25" Opacity="1"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock x:Name="LoadingStatusText"
                                       Margin="0,14,0,0"
                                       Foreground="#EEF8FF"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <Border Margin="0,16,0,0"
                                    Padding="10"
                                    CornerRadius="12"
                                    Background="#13202B"
                                    BorderBrush="#47657C"
                                    BorderThickness="1">
                                <ProgressBar
                                         Margin="0"
                                         x:Name="LoadingProgressBar"
                                         Height="18"
                                         IsIndeterminate="True"/>
                            </Border>
                            <TextBlock x:Name="LoadingProgressText"
                                       Margin="0,10,0,0"
                                       Foreground="#DDF1FF"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
