                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="AudioFxVolumeLabelText" Text="Volume boost" VerticalAlignment="Center" Foreground="#DDF1FF" FontSize="14"/>
                                        <Slider x:Name="AudioVolumeBoostSlider" Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource EffectStrengthSliderStyle}" Minimum="0" Maximum="3" Value="0" ValueChanged="StrengthSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center" TextAlignment="Right" Foreground="#CFEAFF" FontSize="14" Text="{Binding ElementName=AudioVolumeBoostSlider, Path=Value, StringFormat={}{0:0.00}}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="AudioFxEqLowLabelText" Text="EQ Low (dB)" VerticalAlignment="Center" Foreground="#DDF1FF" FontSize="14"/>
                                        <Slider x:Name="AudioEqLowDbSlider" Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource EffectStrengthSliderStyle}" Minimum="-30" Maximum="30" Value="0" ValueChanged="StrengthSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center" TextAlignment="Right" Foreground="#CFEAFF" FontSize="14" Text="{Binding ElementName=AudioEqLowDbSlider, Path=Value, StringFormat={}{0:+0.0;-0.0;0.0}}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="AudioFxEqMidLabelText" Text="EQ Mid (dB)" VerticalAlignment="Center" Foreground="#DDF1FF" FontSize="14"/>
                                        <Slider x:Name="AudioEqMidDbSlider" Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource EffectStrengthSliderStyle}" Minimum="-30" Maximum="30" Value="0" ValueChanged="StrengthSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center" TextAlignment="Right" Foreground="#CFEAFF" FontSize="14" Text="{Binding ElementName=AudioEqMidDbSlider, Path=Value, StringFormat={}{0:+0.0;-0.0;0.0}}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="AudioFxEqHighLabelText" Text="EQ High (dB)" VerticalAlignment="Center" Foreground="#DDF1FF" FontSize="14"/>
                                        <Slider x:Name="AudioEqHighDbSlider" Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource EffectStrengthSliderStyle}" Minimum="-30" Maximum="30" Value="0" ValueChanged="StrengthSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center" TextAlignment="Right" Foreground="#CFEAFF" FontSize="14" Text="{Binding ElementName=AudioEqHighDbSlider, Path=Value, StringFormat={}{0:+0.0;-0.0;0.0}}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="AudioFxPitchLabelText" Text="Pitch (semitones)" VerticalAlignment="Center" Foreground="#DDF1FF" FontSize="14"/>
                                        <Slider x:Name="AudioPitchSemitonesSlider" Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource EffectStrengthSliderStyle}" Minimum="-24" Maximum="24" Value="0" ValueChanged="StrengthSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center" TextAlignment="Right" Foreground="#CFEAFF" FontSize="14" Text="{Binding ElementName=AudioPitchSemitonesSlider, Path=Value, StringFormat={}{0:+0.0;-0.0;0.0}}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="AudioFxReverbLabelText" Text="Reverb" VerticalAlignment="Center" Foreground="#DDF1FF" FontSize="14"/>
                                        <Slider x:Name="AudioReverbStrengthSlider" Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource EffectStrengthSliderStyle}" Minimum="0" Maximum="2" Value="0" ValueChanged="StrengthSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center" TextAlignment="Right" Foreground="#CFEAFF" FontSize="14" Text="{Binding ElementName=AudioReverbStrengthSlider, Path=Value, StringFormat={}{0:0.00}}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="AudioFxEchoLabelText" Text="Echo" VerticalAlignment="Center" Foreground="#DDF1FF" FontSize="14"/>
                                        <Slider x:Name="AudioEchoStrengthSlider" Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource EffectStrengthSliderStyle}" Minimum="0" Maximum="2" Value="0" ValueChanged="StrengthSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center" TextAlignment="Right" Foreground="#CFEAFF" FontSize="14" Text="{Binding ElementName=AudioEchoStrengthSlider, Path=Value, StringFormat={}{0:0.00}}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="AudioFxDistortionLabelText" Text="Distortion" VerticalAlignment="Center" Foreground="#DDF1FF" FontSize="14"/>
                                        <Slider x:Name="AudioDistortionStrengthSlider" Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource EffectStrengthSliderStyle}" Minimum="0" Maximum="2" Value="0" ValueChanged="StrengthSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center" TextAlignment="Right" Foreground="#CFEAFF" FontSize="14" Text="{Binding ElementName=AudioDistortionStrengthSlider, Path=Value, StringFormat={}{0:0.00}}"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="AudioFxWobbleLabelText" Text="Wobble" VerticalAlignment="Center" Foreground="#DDF1FF" FontSize="14"/>
                                        <Slider x:Name="AudioWobbleStrengthSlider" Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource EffectStrengthSliderStyle}" Minimum="0" Maximum="2" Value="0" ValueChanged="StrengthSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center" TextAlignment="Right" Foreground="#CFEAFF" FontSize="14" Text="{Binding ElementName=AudioWobbleStrengthSlider, Path=Value, StringFormat={}{0:0.00}}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem x:Name="EffectsWorkspacePresetsTab"
                                 Header="Presets">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="PresetsSaveCurrentButton"
                                                Grid.Column="0"
                                                Style="{StaticResource PanelModeButtonStyle}"
                                                Content="Save current to slot"
                                                Click="PresetsSaveCurrentButton_Click"/>
                                        <Button x:Name="BackToEffectsFromPresetsButton"
                                                Grid.Column="2"
                                                Style="{StaticResource PanelModeButtonStyle}"
                                                Content="Back to effects"
                                                Click="BackToEffectsFromPresetsButton_Click"/>
                                    </Grid>

                                    <Border Padding="12"
                                            Background="#B21A2733"
                                            BorderBrush="#547A97AE"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock x:Name="PresetBuiltInHeaderText"
                                                       Text="Built-in presets"
                                                       Foreground="#EDF7FF"
                                                       FontSize="18"
                                                       FontWeight="Bold"/>
                                            <TextBlock x:Name="PresetBuiltInHintText"
                                                       Margin="0,4,0,10"
                                                       Text="Quick styles for visuals and audio. You can tweak them after applying."
                                                       Foreground="#BFDCF0"
                                                       TextWrapping="Wrap"
                                                       FontSize="13"/>

                                            <UniformGrid Rows="6" Columns="2">
                                                <Button x:Name="PresetJNightmareButton" Margin="0,0,6,6" Padding="10,7" FontSize="13" Tag="j_nightmare" Click="ApplyBuiltInPresetButton_Click" Content="JNightmare"/>
                                                <Button x:Name="PresetJFireButton" Margin="6,0,0,6" Padding="10,7" FontSize="13" Tag="j_fire" Click="ApplyBuiltInPresetButton_Click" Content="JFire"/>
                                                <Button x:Name="PresetJRelaxingButton" Margin="0,6,6,6" Padding="10,7" FontSize="13" Tag="j_relaxing" Click="ApplyBuiltInPresetButton_Click" Content="JRelaxing"/>
                                                <Button x:Name="PresetRetroButton" Margin="6,6,0,6" Padding="10,7" FontSize="13" Tag="retro_vhs" Click="ApplyBuiltInPresetButton_Click" Content="Retro VHS"/>
                                                <Button x:Name="PresetDreamButton" Margin="0,6,6,6" Padding="10,7" FontSize="13" Tag="dream" Click="ApplyBuiltInPresetButton_Click" Content="Dream Glow"/>
                                                <Button x:Name="PresetChaosButton" Margin="6,6,0,6" Padding="10,7" FontSize="13" Tag="chaos" Click="ApplyBuiltInPresetButton_Click" Content="Chaos"/>
                                                <Button x:Name="PresetCinemaButton" Margin="0,6,6,6" Padding="10,7" FontSize="13" Tag="cinema" Click="ApplyBuiltInPresetButton_Click" Content="Cinema Cold"/>
                                                <Button x:Name="PresetBlurButton" Margin="6,6,0,6" Padding="10,7" FontSize="13" Tag="deep_blur" Click="ApplyBuiltInPresetButton_Click" Content="Deep Blur"/>
                                                <Button x:Name="PresetColdGlitchButton" Margin="0,6,6,0" Padding="10,7" FontSize="13" Tag="cold_glitch" Click="ApplyBuiltInPresetButton_Click" Content="Cold Glitch"/>
                                                <Button x:Name="PresetDemonTunnelButton" Margin="6,6,0,0" Padding="10,7" FontSize="13" Tag="demon_tunnel" Click="ApplyBuiltInPresetButton_Click" Content="Demon Tunnel"/>
                                                <Button x:Name="PresetMirrorPrisonButton" Margin="0,6,6,0" Padding="10,7" FontSize="13" Tag="mirror_prison" Click="ApplyBuiltInPresetButton_Click" Content="Mirror Prison"/>
                                                <Button x:Name="PresetPoisonTapeButton" Margin="6,6,0,0" Padding="10,7" FontSize="13" Tag="poison_tape" Click="ApplyBuiltInPresetButton_Click" Content="Poison Tape"/>
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,12,0,0"
                                            Padding="12"
                                            Background="#B21A2733"
                                            BorderBrush="#547A97AE"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock x:Name="CustomPresetHeaderText"
                                                       Text="Custom presets (up to 20)"
                                                       Foreground="#EDF7FF"
                                                       FontSize="18"
                                                       FontWeight="Bold"/>
                                            <TextBlock x:Name="CustomPresetHintText"
                                                       Margin="0,4,0,10"
                                                       Text="Choose a slot, name it, save current FX setup, and load it later."
                                                       Foreground="#BFDCF0"
                                                       TextWrapping="Wrap"
                                                       FontSize="13"/>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox x:Name="CustomPresetSlotComboBox"
                                                          Height="40"
                                                          FontSize="14"
                                                          SelectionChanged="PresetSlotComboBox_SelectionChanged"/>
                                                <Button x:Name="LoadCustomPresetButton"
                                                        Grid.Column="2"
                                                        Padding="12,8"
                                                        FontSize="13"
                                                        Content="Load selected"
                                                        Click="LoadCustomPresetButton_Click"/>
                                            </Grid>

                                            <Grid Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="CustomPresetNameTextBox"
                                                         Height="40"
                                                         FontSize="14"
                                                         VerticalContentAlignment="Center"
                                                         KeyDown="CustomPresetNameTextBox_KeyDown"/>
                                                <Button x:Name="SaveCustomPresetButton"
                                                        Grid.Column="2"
                                                        Padding="14,8"
                                                        FontSize="13"
                                                        Content="Save"
                                                        Click="SaveCustomPresetButton_Click"/>
                                            </Grid>

                                            <Grid Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="DeleteCustomPresetButton"
                                                        Grid.Column="0"
                                                        Padding="12,8"
                                                        FontSize="13"
                                                        Content="Clear slot"
                                                        Click="DeleteCustomPresetButton_Click"/>
                                                <Button x:Name="ApplyAndBackPresetButton"
                                                        Grid.Column="2"
                                                        Padding="12,8"
                                                        FontSize="13"
                                                        Content="Back to effects"
                                                        Click="BackToEffectsFromPresetsButton_Click"/>
                                            </Grid>

                                            <TextBlock x:Name="PresetStatusText"
                                                       Margin="0,10,0,0"
                                                       Foreground="#9CD0EE"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem x:Name="EffectsWorkspaceTimecodesTab"
                                 Header="Таймкоды">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header row -->
                                <Grid Grid.Row="0">
                                     <Grid.RowDefinitions>
                                         <RowDefinition Height="Auto"/>
                                         <RowDefinition Height="Auto"/>
                                         <RowDefinition Height="Auto"/>
                                     </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="TimecodesPanelHeaderText"
                                                   Grid.Column="0"
                                                   Text="Сохранённые клипы"
                                                   Foreground="#EDF7FF"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Button x:Name="TimecodeAddFromPanelButton"
                                                Grid.Column="2"
                                                Style="{StaticResource PanelModeButtonStyle}"
                                                Padding="10,5"
                                                FontSize="12"
                                                Content="+ Клип"
                                                Click="TimecodeAddFromPanelButton_Click"/>
                                    </Grid>
                                    <!-- How-to hint -->
                                    <TextBlock x:Name="TimecodesPanelHintText"
                                               Grid.Row="1"
                                               Margin="0,4,0,0"
                                               Text="Нажми M или кнопку + Клип, чтобы сохранить позицию в видео."
                                               Foreground="#486A80"
                                               FontSize="11"
                                               TextWrapping="Wrap"/>
                                    <StackPanel Grid.Row="2"
                                                Margin="0,10,0,0">
                                        <TextBlock x:Name="TimecodesPanelSummaryText"
                                                   Text="Сначала показываются таймкоды этого видео, затем остальные."
                                                   Foreground="#8FC4E4"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>
                                        <Grid>
                                            <TextBox x:Name="TimecodesSearchBox"
                                                     Height="34"
                                                     Padding="12,6"
                                                     FontSize="13"
                                                     Background="#C9162533"
                                                     BorderBrush="#5A85A1"
                                                     Foreground="#EAF6FF"
                                                     TextChanged="TimecodesSearchBox_TextChanged"
                                                     GotFocus="TimecodesSearchBox_GotFocus"
                                                     LostFocus="TimecodesSearchBox_LostFocus"/>
                                            <TextBlock x:Name="TimecodesSearchPlaceholderText"
                                                       Text="Поиск по названию, времени или видео..."
                                                       Margin="14,0,34,0"
                                                       Foreground="#6E93AB"
                                                       VerticalAlignment="Center"
                                                       IsHitTestVisible="False"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <!-- Clips list -->
                                <ScrollViewer Grid.Row="2"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel>
                                        <TextBlock x:Name="TimecodesPanelEmptyText"
                                                   Text="Нет сохранённых клипов. Нажми + Клип во время просмотра."
                                                   Foreground="#8FAFC8"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   Visibility="Visible"
                                                   Margin="0,4,0,0"/>

                                        <ItemsControl x:Name="TimecodesPanelList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <!-- Clip card -->
                                                    <Border Margin="0,0,0,7"
                                                            CornerRadius="10"
                                                            ClipToBounds="True"
                                                            MouseLeftButtonDown="TimecodeItem_MouseLeftButtonDown"
                                                            PreviewMouseRightButtonUp="TimecodeItem_RightClick">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#B0142233"/>
                                                                <Setter Property="BorderBrush" Value="#33607A8A"/>
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCurrentVideo}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="#554E9DD4"/>
                                                                        <Setter Property="Background" Value="#C0122740"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>

                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="92"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Thumbnail with time badge -->
                                                            <Grid Grid.Column="0"
                                                                  Width="92" Height="54"
                                                                  Background="#0A1820">
                                                                <Image Source="{Binding ThumbnailUrl}"
                                                                       Stretch="UniformToFill"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                                <!-- Time badge over thumbnail -->
                                                                <Border VerticalAlignment="Bottom"
                                                                        HorizontalAlignment="Right"
                                                                        Margin="0,0,3,3"
                                                                        Padding="4,1"
                                                                        Background="#CC000000"
                                                                        CornerRadius="3">
                                                                    <TextBlock Text="{Binding TimeFormatted}"
                                                                               Foreground="#F0FAFF"
                                                                               FontSize="10"
                                                                               FontWeight="Bold"/>
                                                                </Border>
                                                                <!-- "current" dot indicator -->
                                                                <Ellipse Width="7" Height="7"
                                                                         HorizontalAlignment="Left"
                                                                         VerticalAlignment="Top"
                                                                         Margin="4,4,0,0">
                                                                    <Ellipse.Style>
                                                                        <Style TargetType="Ellipse">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Setter Property="Fill" Value="#4EC5F0"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsCurrentVideo}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Ellipse.Style>
                                                                </Ellipse>
                                                            </Grid>

                                                            <!-- Clip info -->
                                                            <Grid Grid.Column="1" Margin="8,5,6,5">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="*"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>

                                                                <!-- Video title (only for clips from other videos) -->
                                                                <TextBlock Grid.Row="0"
                                                                           Text="{Binding VideoTitle}"
                                                                           FontSize="10"
                                                                           Foreground="#5B92B2"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Margin="0,0,0,1">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsCurrentVideo}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>

                                                                <!-- Clip label -->
                                                                <TextBlock Grid.Row="1"
                                                                           Text="{Binding Label}"
                                                                           Foreground="#EDF7FF"
                                                                           FontSize="13"
                                                                           FontWeight="SemiBold"
                                                                           TextTrimming="CharacterEllipsis"/>

                                                                <!-- Saved date -->
                                                                <TextBlock Grid.Row="2"
                                                                           Text="{Binding SavedAtText}"
                                                                           Foreground="#476A82"
                                                                           FontSize="10"
                                                                           Margin="0,2,0,0"
                                                                           VerticalAlignment="Bottom"/>

                                                                <!-- Action buttons -->
                                                                <StackPanel Grid.Row="3"
                                                                            Orientation="Horizontal"
                                                                            HorizontalAlignment="Right"
                                                                            Margin="0,4,0,0">
                                                                    <!-- Seek button — only for current video -->
                                                                    <Button Padding="6,3"
                                                                            FontSize="11"
                                                                            Margin="0,0,4,0"
                                                                            Tag="{Binding Seconds}"
                                                                            Click="TimecodeItem_SeekClick">
                                                                        <Button.Style>
                                                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                                                <Setter Property="Content" Value="▶ Перейти"/>
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsCurrentVideo}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                    <!-- Delete -->
                                                                    <Button Content="✕"
                                                                            Padding="6,3"
                                                                            FontSize="11"
                                                                            Tag="{Binding Id}"
                                                                            Click="TimecodeDeleteButton_Click"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </TabItem>
                        <TabItem x:Name="EffectsWorkspaceCommunityTab"
                                 Header="Обсуждение">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="CommunityPanelHeaderText"
                                           Grid.Row="0"
                                           Text="Комментарии и чат"
                                           Foreground="#EDF7FF"
                                           FontSize="18"
                                           FontWeight="Bold"/>

                                <TextBlock x:Name="CommunityPanelHintText"
                                           Grid.Row="1"
                                           Margin="0,4,0,0"
                                           Text="Открывай комментарии или чат стрима здесь. Сам YouTube-плеер их не разворачивает."
                                           Foreground="#8FC4E4"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>

                                <Grid Grid.Row="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button x:Name="CommunityShowCommentsButton"
                                            Grid.Column="0"
                                            Style="{StaticResource PanelModeButtonStyle}"
                                            Content="Комментарии"
                                            Click="CommunityShowCommentsButton_Click"/>

                                    <Button x:Name="CommunityShowChatButton"
                                            Grid.Column="2"
                                            Style="{StaticResource PanelModeButtonStyle}"
                                            Content="Чат"
                                            Click="CommunityShowChatButton_Click"/>

                                    <Button x:Name="CommunityReloadButton"
                                            Grid.Column="4"
                                            Padding="12,8"
                                            FontSize="13"
                                            Content="Обновить"
                                            Click="CommunityReloadButton_Click"/>
                                </Grid>

                                <Border Grid.Row="5"
                                        Background="#B0142233"
                                        BorderBrush="#547A97AE"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        ClipToBounds="True">
                                    <Grid>
                                        <wv2:WebView2 x:Name="CommunityBrowser"
                                                      Visibility="Collapsed"/>

                                        <Border x:Name="CommunityBrowserOverlay"
                                                Background="#E4172432"
                                                Visibility="Visible"
                                                IsHitTestVisible="False">
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        MaxWidth="300">
                                                <TextBlock x:Name="CommunityBrowserOverlayHeaderText"
                                                           Text="Подготовка обсуждения"
                                                           Foreground="#EDF7FF"
                                                           FontSize="18"
                                                           FontWeight="Bold"
                                                           TextAlignment="Center"/>
                                                <TextBlock x:Name="CommunityBrowserOverlayText"
                                                           Margin="0,8,0,0"
                                                           Text="Загружаю комментарии и чат этого видео..."
                                                           Foreground="#BFDCEC"
                                                           FontSize="12"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <TextBlock x:Name="CommunityStatusText"
                                           Grid.Row="6"
                                           Margin="0,10,0,0"
                                           Foreground="#8FC4E4"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
