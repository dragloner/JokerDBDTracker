<Window x:Class="JokerDBDTracker.PlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:JokerDBDTracker"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="JokerDBD Tracker - Player"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="CanResize"
        Width="1480"
        Height="900"
        MinWidth="760"
        MinHeight="460"
        WindowStartupLocation="Manual"
        Background="#131B22"
        Icon="Assets/app.ico"
        FontFamily="Bahnschrift SemiCondensed">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="12"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F3FAFF"/>
            <Setter Property="Background" Value="#CC193344"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="BorderBrush" Value="#5C86A2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="TextBlock.TextWrapping" Value="NoWrap"/>
            <Setter Property="TextBlock.TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="TextBlock.TextAlignment" Value="Center"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid ClipToBounds="False">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="18"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                            </Border>
                            <Border Background="Transparent"
                                    ClipToBounds="True"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#88CFFF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="ui:UiAnimation.IsEnabled" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                                    </Setter.Value>
                                </Setter>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsPressed" Value="True"/>
                                    <Condition Property="ui:UiAnimation.IsEnabled" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.985" ScaleY="0.985"/>
                                    </Setter.Value>
                                </Setter>
                            </MultiTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.94"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BackButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="21"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="Background" Value="#CC214C65"/>
        </Style>

        <Style x:Key="EffectButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="19"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Background" Value="#CC1C4055"/>
        </Style>

        <Style x:Key="PanelModeButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Background" Value="#C71B3548"/>
        </Style>

        <Style x:Key="WindowControlButtonStyle" TargetType="Button" BasedOn="{StaticResource EffectButtonStyle}">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Background" Value="#CC183548"/>
            <Setter Property="BorderBrush" Value="#5E88A5"/>
        </Style>

        <Style x:Key="WindowCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowControlButtonStyle}">
            <Setter Property="Background" Value="#CC5E2835"/>
            <Setter Property="BorderBrush" Value="#A86C79"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#EAF6FF"/>
            <Setter Property="Background" Value="#C9162533"/>
            <Setter Property="BorderBrush" Value="#5A85A1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="TextElement.Foreground" Value="#EAF6FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border x:Name="PopupRoot"
                                        MinWidth="{Binding ActualWidth, ElementName=ComboRoot}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Margin="0,6,0,0"
                                        Background="#EF11202D"
                                        BorderBrush="#4F7894"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="14"
                                                          ShadowDepth="0"
                                                          Color="#05090D"
                                                          Opacity="0.42"/>
                                    </Border.Effect>
                                    <Border Margin="3"
                                            Background="#152736"
                                            CornerRadius="9">
                                        <ScrollViewer Margin="1"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Border>
                            </Popup>

                            <Border x:Name="ComboRoot"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12">
                                <Grid ClipToBounds="True">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter x:Name="SelectionContent"
                                                      Grid.Column="0"
                                                      Margin="12,0,8,0"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"
                                                      RecognizesAccessKey="True"
                                                      IsHitTestVisible="False"/>

                                    <TextBox x:Name="PART_EditableTextBox"
                                             Grid.Column="0"
                                             Margin="12,0,8,0"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{TemplateBinding Foreground}"
                                             CaretBrush="{TemplateBinding Foreground}"
                                             HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                             VerticalContentAlignment="Center"
                                             IsReadOnly="{TemplateBinding IsReadOnly}"
                                             Visibility="Hidden"/>

                                    <ToggleButton x:Name="DropDownToggle"
                                                  Grid.ColumnSpan="2"
                                                  Focusable="False"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>

                                    <Border x:Name="ArrowHost"
                                            Grid.Column="1"
                                            CornerRadius="0,12,12,0"
                                            Background="#182C3D"
                                            BorderBrush="#345A72"
                                            BorderThickness="1,0,0,0"
                                            IsHitTestVisible="False">
                                        <Path Width="10"
                                              Height="6"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Fill="#C9E8FB"
                                              Data="M 0 0 L 10 0 L 5 6 Z"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="SelectionContent" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="DropDownToggle" Property="Grid.Column" Value="1"/>
                                <Setter TargetName="DropDownToggle" Property="Grid.ColumnSpan" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboRoot" Property="BorderBrush" Value="#86C6EC"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboRoot" Property="BorderBrush" Value="#9AD5FB"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboRoot" Property="BorderBrush" Value="#9AD5FB"/>
                                <Setter TargetName="ArrowHost" Property="Background" Value="#203A4F"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboRoot" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#EAF7FF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemRoot"
                                Margin="2"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="8"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#203646"/>
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="#6EAED6"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#1B4D71"/>
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="#84C8F1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemRoot" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#EAF6FF"/>
            <Setter Property="Background" Value="#C9162533"/>
            <Setter Property="BorderBrush" Value="#5A85A1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#EAF6FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <Border Padding="{TemplateBinding Padding}">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Background="Transparent"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="True"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TextBoxRoot" Property="BorderBrush" Value="#86C6EC"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="TextBoxRoot" Property="BorderBrush" Value="#9AD5FB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TextBoxRoot" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TimecodePopupTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinHeight" Value="56"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Left"/>
        </Style>

        <Style x:Key="PlayerPanelTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Border
                                    Background="#96121B25"
                                    BorderBrush="#34546B"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="8">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayerPanelTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="#E9F6FF"/>
            <Setter Property="Background" Value="#C9182E3F"/>
            <Setter Property="BorderBrush" Value="#4C738E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabRoot" Property="BorderBrush" Value="#88CFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabRoot" Property="Background" Value="#E0223D50"/>
                                <Setter TargetName="TabRoot" Property="BorderBrush" Value="#7BC8F4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EffectCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EAF5FF"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Root"
                                Background="#CC2A3D4E"
                                BorderBrush="#6887A0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="Mark"
                                        Width="24"
                                        Height="24"
                                        CornerRadius="12"
                                        Background="#1B2A36"
                                        BorderBrush="#7B9BB2"
                                        BorderThickness="1">
                                    <TextBlock x:Name="MarkGlyph"
                                               Text=""
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontWeight="ExtraBold"
                                               FontSize="16"
                                               Foreground="#D8F5E8"/>
                                </Border>
                                <ContentPresenter Grid.Column="2"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#97BFD9"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#D7334B60"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#8CB8D4"/>
                                <Setter TargetName="Mark" Property="Background" Value="#2FA27E"/>
                                <Setter TargetName="Mark" Property="BorderBrush" Value="#95E7C9"/>
                                <Setter TargetName="MarkGlyph" Property="Text" Value="&#x2714;"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EffectStrengthThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Background="{x:Null}"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True">
                            <Ellipse x:Name="Glow"
                                     Width="24"
                                     Height="24"
                                     Fill="#249FDEFF"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Opacity="0"
                                     IsHitTestVisible="False"/>
                            <Ellipse x:Name="Outer"
                                     Width="{TemplateBinding Width}"
                                     Height="{TemplateBinding Height}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     StrokeThickness="1"
                                     Stroke="#B4E8FFFF">
                                <Ellipse.Fill>
                                    <RadialGradientBrush Center="0.35,0.28" GradientOrigin="0.35,0.28" RadiusX="0.82" RadiusY="0.82">
                                        <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                        <GradientStop Color="#EBF7FEFF" Offset="0.45"/>
                                        <GradientStop Color="#C7DEEEFF" Offset="0.82"/>
                                        <GradientStop Color="#A9C5D9EF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse x:Name="Inner"
                                     Width="10"
                                     Height="10"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Fill="#F6FCFF"
                                     Stroke="#7CB7DB"
                                     StrokeThickness="0.9"/>
                            <Ellipse x:Name="Specular"
                                     Width="8"
                                     Height="3.5"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Top"
                                     Margin="0,4,0,0"
                                     Fill="#B9FFFFFF"
                                     IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Glow" Property="Opacity" Value="0.55"/>
                                <Setter TargetName="Outer" Property="Stroke" Value="#E8FFFFFF"/>
                                <Setter TargetName="Inner" Property="Stroke" Value="#8CCAF0"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Glow" Property="Opacity" Value="0.8"/>
                                <Setter TargetName="Outer" Property="Stroke" Value="#FFFFFFFF"/>
                                <Setter TargetName="Inner" Property="Fill" Value="#FFFFFF"/>
                                <Setter TargetName="Inner" Property="Stroke" Value="#A6DCF9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Glow" Property="Opacity" Value="0"/>
                                <Setter TargetName="Outer" Property="Opacity" Value="0.55"/>
                                <Setter TargetName="Inner" Property="Opacity" Value="0.6"/>
                                <Setter TargetName="Specular" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EffectSliderDecreaseButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Grid Background="{x:Null}"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True">
                            <Border x:Name="FillBar"
                                    Height="10"
                                    VerticalAlignment="Center"
                                    CornerRadius="5,0,0,5"
                                    BorderThickness="1"
                                    BorderBrush="#48B5DFFF">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#273B4D5D" Offset="0"/>
                                        <GradientStop Color="#3C5E7890" Offset="0.45"/>
                                        <GradientStop Color="#5EA6D6F2" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Border x:Name="FillGloss"
                                    Height="4"
                                    Margin="1,0,0,5"
                                    VerticalAlignment="Center"
                                    CornerRadius="4,0,0,3"
                                    Background="#20FFFFFF"
                                    IsHitTestVisible="False"/>
                            <Border x:Name="FillEdge"
                                    Height="10"
                                    VerticalAlignment="Center"
                                    CornerRadius="5,0,0,5"
                                    BorderThickness="1"
                                    BorderBrush="#48B5DFFF"
                                    Background="Transparent"
                                    IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FillGloss" Property="Opacity" Value="0.12"/>
                                <Setter TargetName="FillEdge" Property="BorderBrush" Value="#7FD8F9FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FillBar" Property="Opacity" Value="0.35"/>
                                <Setter TargetName="FillGloss" Property="Opacity" Value="0"/>
                                <Setter TargetName="FillEdge" Property="Opacity" Value="0.25"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EffectSliderIncreaseButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Grid Background="{x:Null}"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True">
                            <Border x:Name="RemainBar"
                                    Height="10"
                                    VerticalAlignment="Center"
                                    CornerRadius="0,5,5,0"
                                    BorderThickness="1"
                                    BorderBrush="#4E9BB7CC">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#6B889DB0" Offset="0"/>
                                        <GradientStop Color="#809CB0C1" Offset="0.55"/>
                                        <GradientStop Color="#96B0C1CF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Border x:Name="RemainGloss"
                                    Height="4"
                                    Margin="0,0,1,5"
                                    VerticalAlignment="Center"
                                    CornerRadius="0,3,4,0"
                                    Background="#16FFFFFF"
                                    IsHitTestVisible="False"/>
                            <Border x:Name="RemainEdge"
                                    Height="10"
                                    VerticalAlignment="Center"
                                    CornerRadius="0,5,5,0"
                                    BorderThickness="1"
                                    BorderBrush="#4E9BB7CC"
                                    Background="Transparent"
                                    IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RemainGloss" Property="Opacity" Value="0.08"/>
                                <Setter TargetName="RemainEdge" Property="BorderBrush" Value="#75BED9EC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RemainBar" Property="Opacity" Value="0.35"/>
                                <Setter TargetName="RemainGloss" Property="Opacity" Value="0"/>
                                <Setter TargetName="RemainEdge" Property="Opacity" Value="0.25"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EffectStrengthSliderStyle" TargetType="Slider">
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Minimum" Value="-1"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="Value" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Margin="0,2,0,2"
                              Background="{x:Null}"
                              VerticalAlignment="Center"
                              UseLayoutRounding="True"
                              SnapsToDevicePixels="True">
                            <Border x:Name="RailShadow"
                                    Height="12"
                                    VerticalAlignment="Center"
                                    CornerRadius="6"
                                    Background="#320A1118"
                                    BorderBrush="#12000000"
                                    BorderThickness="1"/>
                            <Border x:Name="RailBody"
                                    Height="12"
                                    VerticalAlignment="Center"
                                    CornerRadius="6"
                                    BorderThickness="1"
                                    BorderBrush="#4E86A4B8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#CE263748" Offset="0"/>
                                        <GradientStop Color="#D11D2E3D" Offset="0.5"/>
                                        <GradientStop Color="#DB172531" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Border x:Name="RailGlass"
                                    Height="8"
                                    Margin="2,0,2,0"
                                    VerticalAlignment="Center"
                                    CornerRadius="4"
                                    BorderThickness="1"
                                    BorderBrush="#20FFFFFF"
                                    Background="#10FFFFFF"
                                    IsHitTestVisible="False"/>
                            <Border x:Name="RailSpecular"
                                    Height="3"
                                    Margin="3,0,3,5"
                                    VerticalAlignment="Center"
                                    CornerRadius="2"
                                    Background="#19FFFFFF"
                                    IsHitTestVisible="False"/>
                            <Track x:Name="PART_Track"
                                   Margin="1,0,1,0"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Value="{TemplateBinding Value}"
                                   IsDirectionReversed="False"
                                   VerticalAlignment="Stretch">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource EffectSliderDecreaseButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource EffectStrengthThumbStyle}"
                                           VerticalAlignment="Center"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource EffectSliderIncreaseButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RailBody" Property="BorderBrush" Value="#7AAFD1EA"/>
                                <Setter TargetName="RailGlass" Property="BorderBrush" Value="#28FFFFFF"/>
                                <Setter TargetName="RailSpecular" Property="Opacity" Value="0.95"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="RailBody" Property="BorderBrush" Value="#91C3E1F4"/>
                                <Setter TargetName="RailGlass" Property="BorderBrush" Value="#32FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RailShadow" Property="Opacity" Value="0.3"/>
                                <Setter TargetName="RailBody" Property="Opacity" Value="0.45"/>
                                <Setter TargetName="RailGlass" Property="Opacity" Value="0.25"/>
                                <Setter TargetName="RailSpecular" Property="Opacity" Value="0.1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AppScrollThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="12"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid SnapsToDevicePixels="True"
                              UseLayoutRounding="True">
                            <Border x:Name="ThumbGlow"
                                    Margin="-1"
                                    CornerRadius="6"
                                    Background="#2EBEEBFF"
                                    Opacity="0"
                                    IsHitTestVisible="False"/>
                            <Border x:Name="ThumbBody"
                                    CornerRadius="5"
                                    BorderThickness="1"
                                    BorderBrush="#92EFFFFF">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#E9FCFFFF" Offset="0"/>
                                        <GradientStop Color="#C8F0FCFF" Offset="0.45"/>
                                        <GradientStop Color="#A5DCF3FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Border x:Name="ThumbGlass"
                                    Margin="1"
                                    CornerRadius="4"
                                    BorderThickness="1"
                                    BorderBrush="#28FFFFFF"
                                    Background="#14FFFFFF"
                                    IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbGlow" Property="Opacity" Value="0.6"/>
                                <Setter TargetName="ThumbBody" Property="BorderBrush" Value="#CBFAFFFF"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbGlow" Property="Opacity" Value="0.85"/>
                                <Setter TargetName="ThumbBody" Property="BorderBrush" Value="#F3FFFFFF"/>
                                <Setter TargetName="ThumbGlass" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ThumbBody" Property="Opacity" Value="0.35"/>
                                <Setter TargetName="ThumbGlass" Property="Opacity" Value="0.2"/>
                                <Setter TargetName="ThumbGlow" Property="Opacity" Value="0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppScrollRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="18"/>
            <Setter Property="MinWidth" Value="18"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Opacity" Value="0.5"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
            <Setter Property="ui:ScrollBarRevealBehavior.EnableAutoReveal" Value="True"/>
            <Setter Property="ui:ScrollBarRevealBehavior.RevealEdgeWidth" Value="42"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="ScrollRoot"
                              Background="Transparent"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True">
                            <Border x:Name="ScrollShell"
                                    Margin="1"
                                    CornerRadius="8"
                                    Background="#08121920"
                                    BorderThickness="1"
                                    BorderBrush="#1EFFFFFF"/>
                            <Border x:Name="ScrollRail"
                                    Margin="3,2,3,2"
                                    CornerRadius="6"
                                    Background="#3B101A23"
                                    BorderThickness="1"
                                    BorderBrush="#267EB0C8"/>
                            <Border x:Name="ScrollRailGlass"
                                    Margin="4,3,4,3"
                                    CornerRadius="5"
                                    Background="#12FFFFFF"
                                    Opacity="0.75"
                                    IsHitTestVisible="False"/>
                            <Border x:Name="ScrollRailGlow"
                                    Margin="2,1,2,1"
                                    CornerRadius="7"
                                    Background="#10BCEEFF"
                                    Opacity="0"
                                    IsHitTestVisible="False"/>
                            <Track x:Name="PART_Track"
                                   Orientation="{TemplateBinding Orientation}"
                                   IsDirectionReversed="True"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Value="{TemplateBinding Value}"
                                   ViewportSize="{TemplateBinding ViewportSize}"
                                   Margin="2,1,2,1"
                                   SnapsToDevicePixels="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource AppScrollRepeatButtonStyle}"
                                                  Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource AppScrollThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource AppScrollRepeatButtonStyle}"
                                                  Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ScrollShell" Property="BorderBrush" Value="#36E6FAFF"/>
                                <Setter TargetName="ScrollRail" Property="BorderBrush" Value="#4AAEE0F3"/>
                                <Setter TargetName="ScrollRailGlass" Property="Opacity" Value="1"/>
                                <Setter TargetName="ScrollRailGlow" Property="Opacity" Value="0.55"/>
                            </Trigger>
                            <Trigger Property="IsMouseCaptureWithin" Value="True">
                                <Setter TargetName="ScrollShell" Property="BorderBrush" Value="#5AF0FFFF"/>
                                <Setter TargetName="ScrollRail" Property="BorderBrush" Value="#6CD2EEFF"/>
                                <Setter TargetName="ScrollRailGlow" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Height" Value="0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="ui:ScrollBarRevealBehavior.IsRevealActive" Value="True">
                    <Setter Property="Opacity" Value="0.98"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.98"/>
                </Trigger>
                <Trigger Property="IsMouseCaptureWithin" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Opacity" Value="0.94"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.16"/>
                    <Setter Property="IsHitTestVisible" Value="False"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainRootGrid" Margin="8" MouseLeftButtonDown="MainRootGrid_MouseLeftButtonDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="TopBarPanel"
                 Grid.Row="0"
                 Margin="0,4,0,8"
                 Padding="12,10"
                 Background="#D2162330"
                 BorderBrush="#4D728C"
                 BorderThickness="1"
                 CornerRadius="14"
                 MouseLeftButtonDown="TopBarPanel_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BackToListButton"
                        Grid.Column="0"
                        Content="Назад к списку"
                        Style="{StaticResource BackButtonStyle}"
                        Click="BackButton_Click"/>

                <Button x:Name="ToggleEffectsPanelButton"
                        Grid.Column="2"
                        Content="Скрыть эффекты"
                        Style="{StaticResource EffectButtonStyle}"
                        Click="ToggleEffectsPanelButton_Click"/>

                <Button x:Name="ToggleChatDockButton"
                        Grid.Column="4"
                        Padding="14,8"
                        FontSize="14"
                        Content="Р§Р°С‚ СЃР»РµРІР°"
                        Style="{StaticResource EffectButtonStyle}"
                        Click="ToggleChatDockButton_Click"/>

                <Button x:Name="ToggleCommentsDockButton"
                        Grid.Column="6"
                        Padding="14,8"
                        FontSize="14"
                        Content="РљРѕРјРјРµРЅС‚Р°СЂРёРё СЃРЅРёР·Сѓ"
                        Style="{StaticResource EffectButtonStyle}"
                        Click="ToggleCommentsDockButton_Click"/>

                <TextBlock x:Name="VideoTitleText"
                           Grid.Column="7"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#EDF7FF"
                           FontWeight="Bold"
                           FontSize="28"
                           TextTrimming="CharacterEllipsis"/>

                <Button Grid.Column="9"
                        Content="&#xE921;"
                        Style="{StaticResource WindowControlButtonStyle}"
                        Click="MinimizeButton_Click"/>

                <Button x:Name="WindowSizeButton"
                        Grid.Column="11"
                        Content="&#xE922;"
                        Style="{StaticResource WindowControlButtonStyle}"
                        Click="ToggleWindowSizeButton_Click"/>

                <Button Grid.Column="13"
                        Content="&#xE8BB;"
                        Style="{StaticResource WindowCloseButtonStyle}"
                        Click="CloseWindowButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="EffectsSplitterColumn" Width="10"/>
                <ColumnDefinition x:Name="EffectsColumn" Width="420"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="PlayerHostBorder" Grid.Column="0" Background="#D010171E" CornerRadius="10" Margin="0,8,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="CommunityChatColumn" Width="0"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition x:Name="CommunityCommentsRow" Height="0"/>
                    </Grid.RowDefinitions>

                    <Border x:Name="CommunityChatDock"
                            Grid.Row="0"
                            Grid.Column="0"
                            Margin="8,8,8,8"
                            Padding="12"
                            Background="#DE172635"
                            BorderBrush="#547A97AE"
                            BorderThickness="1"
                            CornerRadius="12"
                            Visibility="Collapsed"
                            IsHitTestVisible="False">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="CommunityChatHeaderText"
                                           Grid.Column="0"
                                           Text="Р§Р°С‚ СЃС‚СЂРёРјР°"
                                           Foreground="#EDF7FF"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="CommunityChatReloadButton"
                                        Grid.Column="2"
                                        Style="{StaticResource PanelModeButtonStyle}"
                                        Padding="10,5"
                                        FontSize="12"
                                        Content="РћР±РЅРѕРІРёС‚СЊ"
                                        Click="CommunityChatReloadButton_Click"/>
                                <Button x:Name="CommunityChatCloseButton"
                                        Grid.Column="4"
                                        Style="{StaticResource PanelModeButtonStyle}"
                                        Padding="10,5"
                                        FontSize="12"
                                        Content="Р—Р°РєСЂС‹С‚СЊ"
                                        Click="CommunityChatCloseButton_Click"/>
                            </Grid>
                            <Border Grid.Row="2"
                                    Background="#B0142233"
                                    BorderBrush="#3B617A91"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    ClipToBounds="True">
                                <Grid>
                                    <wv2:WebView2 x:Name="CommunityChatBrowser"
                                                  Visibility="Collapsed"/>
                                    <Border x:Name="CommunityChatOverlay"
                                            Background="#E4172432"
                                            Visibility="Visible"
                                            IsHitTestVisible="False">
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    MaxWidth="260">
                                            <TextBlock x:Name="CommunityChatOverlayHeaderText"
                                                       Text="РџРѕРґРіРѕС‚РѕРІРєР° С‡Р°С‚Р°"
                                                       Foreground="#EDF7FF"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       TextAlignment="Center"/>
                                            <TextBlock x:Name="CommunityChatOverlayText"
                                                       Margin="0,8,0,0"
                                                       Text="Р—Р°РіСЂСѓР¶Р°СЋ live chat РёР»Рё chat replay..."
                                                       Foreground="#BFDCEC"
                                                       FontSize="12"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                            <TextBlock x:Name="CommunityChatStatusText"
                                       Grid.Row="3"
                                       Margin="0,10,0,0"
                                       Foreground="#8FC4E4"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Border>

                    <Border x:Name="PlayerSurfaceHost"
                            Grid.Row="0"
                            Grid.Column="1"
                            Background="#000000"
                            Visibility="Collapsed">
                        <wv2:WebView2 x:Name="Player"/>
                    </Border>
                    <Border x:Name="PlayerLoadingOverlay"
                            Grid.Row="0"
                            Grid.Column="1"
                            Panel.ZIndex="20"
                            Background="#D50B1118"
                            Visibility="Visible"
                            IsHitTestVisible="True">
                        <Border Width="460"
                                Padding="2"
                                CornerRadius="18"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#86A7CEE6" Offset="0"/>
                                    <GradientStop Color="#5D6E93A8" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border Padding="24"
                                    CornerRadius="16"
                                    Background="#D81E2D3B"
                                    BorderBrush="#5A8FB0C9"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock x:Name="PlayerLoadingHeaderText"
                                               Text="Загрузка плеера"
                                               Foreground="#EDF7FF"
                                               FontSize="30"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="PlayerLoadingText"
                                               Margin="0,10,0,0"
                                               Text="Подготовка YouTube..."
                                               Foreground="#CFE3F1"
                                               FontSize="16"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"/>
                                    <ProgressBar Margin="0,14,0,0"
                                                 Height="14"
                                                 IsIndeterminate="True"/>
                                </StackPanel>
                            </Border>
                        </Border>
                    </Border>

                    <!-- Non-JokerDBD content banner: no XP or quest progress -->
                    <Border x:Name="NonJokerBanner"
                            Grid.Row="0"
                            Grid.Column="1"
                            Panel.ZIndex="25"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top"
                            Background="#D0101820"
                            BorderBrush="#33557788"
                            BorderThickness="0,0,0,1"
                            Padding="12,7"
                            Visibility="Collapsed"
                            IsHitTestVisible="False">
                        <TextBlock x:Name="NonJokerBannerText"
                                   Text="⚠ Стороннее видео — XP и задания не начисляются"
                                   Foreground="#FFCC55"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   TextWrapping="NoWrap"
                                   TextOptions.TextFormattingMode="Display"/>
                    </Border>

                    <!-- Blocked navigation toast -->
                    <Border x:Name="BlockedNavToast"
                            Grid.Row="0"
                            Grid.Column="1"
                            Panel.ZIndex="30"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,48"
                            Padding="20,12"
                            Background="#E0152030"
                            BorderBrush="#7AAED4"
                            BorderThickness="1"
                            CornerRadius="12"
                            Visibility="Collapsed"
                            IsHitTestVisible="False">
                        <TextBlock x:Name="BlockedNavToastText"
                                   Text="🔒 Только видео YouTube"
                                   Foreground="#EDF7FF"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   TextAlignment="Center"/>
                    </Border>

                    <!-- Timecode save popup (shown on hotkey M) -->
                    <Popup x:Name="TimecodePopup"
                           PlacementTarget="{Binding ElementName=PlayerHostBorder}"
                           Placement="Center"
                           AllowsTransparency="True"
                           StaysOpen="True"
                           PopupAnimation="Fade"
                           IsOpen="False">
                        <Border MinWidth="560"
                                MaxWidth="640"
                                Padding="20,18"
                                Background="#EF0F1D2B"
                                BorderBrush="#6BAFD5"
                                BorderThickness="1"
                                CornerRadius="14">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#05090D" Opacity="0.55"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock x:Name="TimecodePopupHeaderText"
                                       Text="💾 Сохранить клип"
                                       Foreground="#EDF7FF"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="TimecodePopupHintText"
                                       Text="Сохрани важный момент и дай ему понятное название."
                                       Foreground="#8FC4E4"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>
                            <TextBlock x:Name="TimecodePopupTimeText"
                                       Text="00:00:00"
                                       Foreground="#9CD0EE"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>
                            <TextBlock x:Name="TimecodePopupLabelCaptionText"
                                       Text="Название таймкода"
                                       Foreground="#CFEAFF"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="TimecodePopupLabelBox"
                                     Style="{StaticResource TimecodePopupTextBoxStyle}"
                                     MaxLength="80"
                                     Background="#D4172635"
                                     BorderBrush="#5A85A1"
                                     BorderThickness="1"
                                     Foreground="#EDF7FF"
                                     CaretBrush="#EDF7FF"
                                     SelectionBrush="#5A9FD2"
                                     SelectionOpacity="0.35"
                                     VerticalContentAlignment="Center"
                                     KeyDown="TimecodePopupLabelBox_KeyDown"
                                     Tag="Название клипа (необязательно)"/>
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
